{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "arxiv-latex": {
      "command": "bash",
      "args": [
        "-c",
        "cd ~/.local/share/mcp/arxiv-latex-mcp && uv run server/main.py"
      ]
    },
    "academic-search": {
      "command": "bash",
      "args": [
        "-c",
        "cd ~/.local/share/mcp/academic-search-mcp && uv run server.py"
      ]
    },
    "gemini-cli": {
      "command": "npx",
      "args": ["-y", "gemini-mcp-tool"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "codex-cli": {
      "command": "bash",
      "args": ["-c", "codex mcp-server"]
    }
  }
}
