{
  "mcpServers": {
    "arxiv-latex": {
      "command": "bash",
      "args": [
        "-c",
        "cd ~/.local/share/mcp/arxiv-latex-mcp && uv run server/main.py"
      ]
    },
    "paper-search": {
      "command": "bash",
      "args": [
        "-c",
        "cd ~/.local/share/mcp/paper-search-mcp && uv run python -m paper_search_mcp.server"
      ]
    }
  }
}
