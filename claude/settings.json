{
  "respectGitignore": true,
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "Skill",
      "mcp__lean-ctx__ctx_read",
      "mcp__lean-ctx__ctx_shell",
      "mcp__lean-ctx__ctx_search",
      "mcp__lean-ctx__ctx_tree",
      "mcp__lean-ctx__ctx_smart_read",
      "mcp__lean-ctx__ctx_multi_read",
      "mcp__lean-ctx__ctx_overview",
      "mcp__lean-ctx__ctx_context",
      "mcp__lean-ctx__ctx_session",
      "mcp__lean-ctx__ctx_knowledge",
      "mcp__lean-ctx__ctx_discover",
      "mcp__lean-ctx__ctx_graph",
      "mcp__lean-ctx__ctx_metrics",
      "mcp__lean-ctx__ctx_compress",
      "mcp__lean-ctx__ctx_delta",
      "mcp__lean-ctx__ctx_dedup",
      "mcp__lean-ctx__ctx_fill",
      "mcp__lean-ctx__ctx_cache",
      "mcp__lean-ctx__ctx_preload",
      "mcp__lean-ctx__ctx_analyze",
      "mcp__lean-ctx__ctx_benchmark",
      "mcp__lean-ctx__ctx_intent",
      "mcp__lean-ctx__ctx_semantic_search",
      "mcp__lean-ctx__ctx_response",
      "mcp__lean-ctx__ctx_agent",
      "mcp__lean-ctx__ctx_wrapped",
      "mcp__plugin_telegram_telegram__reply",
      "mcp__plugin_telegram_telegram__react",
      "mcp__plugin_telegram_telegram__edit_message",
      "mcp__plugin_telegram_telegram__download_attachment"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.jks)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/.gnupg/**)",
      "Read(**/.kube/config)",
      "Read(**/.docker/config.json)",
      "Read(**/.config/gh/hosts.yml)",
      "Read(**/.npmrc)",
      "Read(**/.netrc)",
      "Read(**/credentials*)",
      "Read(**/secrets/**)",
      "Read(**/*_history)",
      "Write(**/.env*)",
      "Write(**/*.pem)",
      "Write(**/*.key)",
      "Write(**/*.p12)",
      "Write(**/*.jks)",
      "Write(**/.ssh/**)",
      "Write(**/.aws/**)",
      "Write(**/.gnupg/**)",
      "Write(**/.kube/config)",
      "Write(**/.docker/config.json)",
      "Write(**/.npmrc)",
      "Write(**/.netrc)",
      "Write(**/credentials*)",
      "Write(**/secrets/**)",
      "Write(**/*_history)",
      "Edit(**/.env*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/.ssh/**)",
      "Edit(**/.aws/**)",
      "Edit(**/.gnupg/**)",
      "Edit(**/.npmrc)",
      "Edit(**/.netrc)",
      "Edit(**/credentials*)",
      "Edit(**/secrets/**)",
      "Edit(**/*_history)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(chmod -R 777 *)"
    ],
    "additionalDirectories": [
      "~"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/gmoh/.claude/hooks/lean-ctx-rewrite.sh"
          },
          {
            "type": "command",
            "command": "/home/gmoh/.claude/hooks/block-ai-after-compact.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/gmoh/.claude/hooks/auto-verify.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/gmoh/.claude/hooks/precompact-guard.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/gmoh/.claude/hooks/postcompact-mark.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/gmoh/.claude/hooks/postcompact-warn.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "python3 ~/.claude/statusline.py"
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "claude-scientific-writer@claude-scientific-writer": true,
    "code-review@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-scientific-writer": {
      "source": {
        "source": "git",
        "url": "https://github.com/K-Dense-AI/claude-scientific-writer.git"
      }
    }
  },
  "effortLevel": "medium"
}
