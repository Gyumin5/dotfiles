[Unit]
Description=Claude Code session for intensitylio (telegram remote-control)
After=network-online.target
Wants=network-online.target
ConditionPathExists=/home/gmoh/av-ros/test/intensitylio/.claude/telegram/.env

[Service]
Type=simple
WorkingDirectory=/home/gmoh/av-ros/test/intensitylio
Environment="CLAUDE_SESSION_NAME=intensitylio"
Environment="PATH=/home/gmoh/.bun/bin:/home/gmoh/.nvm/versions/node/v22.17.0/bin:/home/gmoh/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="TELEGRAM_STATE_DIR=/home/gmoh/av-ros/test/intensitylio/.claude/telegram"
Environment="TERM=xterm-256color"
ExecStart=/home/gmoh/.local/bin/claude-service-exec
ExecStartPost=/home/gmoh/.local/bin/claude-service-notify start claude-intensitylio
ExecStopPost=/home/gmoh/.local/bin/claude-service-notify stop claude-intensitylio
Restart=always
RestartSec=5
StandardOutput=append:/home/gmoh/.claude/logs/claude-intensitylio.log
StandardError=append:/home/gmoh/.claude/logs/claude-intensitylio.log
KillMode=mixed
TimeoutStopSec=20

[Install]
WantedBy=default.target
