[Unit]
Description=Claude Progress Updater (all cs-managed projects)

[Service]
Type=oneshot
Environment="PATH=/home/gmoh/.bun/bin:/home/gmoh/.nvm/versions/node/v22.17.0/bin:/home/gmoh/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="UPDATER_AUTO_MERGE=1"
ExecStart=/home/gmoh/.local/bin/claude-progress-updater-all
StandardOutput=append:/home/gmoh/.claude/logs/progress-updater.svc.log
StandardError=append:/home/gmoh/.claude/logs/progress-updater.svc.log
