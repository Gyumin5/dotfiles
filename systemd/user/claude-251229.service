[Unit]
Description=Claude Code session for 251229 (telegram remote-control)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/gmoh/mon/251229
Environment="PATH=/home/gmoh/.bun/bin:/home/gmoh/.nvm/versions/node/v22.17.0/bin:/home/gmoh/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="TELEGRAM_STATE_DIR=/home/gmoh/mon/251229/.claude/telegram"
Environment="TERM=xterm-256color"
ExecStart=/bin/bash -c 'exec script -q -c "claude -c --remote-control --channels plugin:telegram@claude-plugins-official" /dev/null < /dev/null || exec script -q -c "claude --remote-control --channels plugin:telegram@claude-plugins-official" /dev/null < /dev/null'
ExecStartPost=/home/gmoh/.local/bin/claude-service-notify start claude-251229
ExecStopPost=/home/gmoh/.local/bin/claude-service-notify stop claude-251229
Restart=on-failure
RestartSec=5
StandardOutput=append:/home/gmoh/.claude/logs/claude-251229.log
StandardError=append:/home/gmoh/.claude/logs/claude-251229.log
KillMode=mixed
TimeoutStopSec=20

[Install]
WantedBy=default.target
