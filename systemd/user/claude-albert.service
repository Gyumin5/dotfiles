[Unit]
Description=Claude Code session for albert (telegram remote-control)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/gmoh/albert
Environment="PATH=/home/gmoh/.bun/bin:/home/gmoh/.nvm/versions/node/v22.17.0/bin:/home/gmoh/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="TELEGRAM_STATE_DIR=/home/gmoh/albert/.claude/telegram"
Environment="TERM=xterm-256color"
ExecStart=/home/gmoh/.local/bin/claude-service-exec
ExecStartPost=/home/gmoh/.local/bin/claude-service-notify start claude-albert
ExecStopPost=/home/gmoh/.local/bin/claude-service-notify stop claude-albert
Restart=on-failure
RestartSec=5
StandardOutput=append:/home/gmoh/.claude/logs/claude-albert.log
StandardError=append:/home/gmoh/.claude/logs/claude-albert.log
KillMode=mixed
TimeoutStopSec=20

[Install]
WantedBy=default.target
