#!/usr/bin/env python3
"""claude-account-switch — Anthropic 계정 스냅샷/헤드리스 전환.

여러 계정(회사/개인)을 한 번씩 인터랙티브 로그인해 스냅샷으로 떠두면,
이후 재로그인 없이 스냅샷 교체만으로 계정을 바꾼다.

스냅샷 = ~/.claude/.credentials.json(OAuth 토큰) + ~/.claude.json 의
oauthAccount 블록. 자격증명 내용은 절대 출력하지 않는다(파일 복사만).

명령:
  snapshot <label>   현재 로그인 계정을 <label> 로 저장
  list               저장된 스냅샷 + 현재 계정
  current            현재 로그인 계정 이메일만 출력
  use <label>        <label> 스냅샷으로 전환(재로그인 불필요)

전환 후: statusline_cache 삭제로 강제 갱신. rate-limit-guard 는 계정 불일치를
자동 감지해 막지 않으므로 대화를 바로 이어가면 새 계정 사용량으로 갱신된다.
세션 재시작은 불필요(-c 로 대화 보존되지만, 토큰만 갈아끼우면 그대로 동작).

주의:
- 스냅샷은 ~/.claude/account-snapshots/ (700) 에만. git/repo 에 넣지 말 것.
- refresh_token 이 만료되면 해당 스냅샷은 재로그인 후 다시 snapshot 필요.
- 회사 머신에 개인계정(또는 그 반대) creds 저장은 보안 트레이드오프.
"""
import json
import os
import shutil
import stat
import sys
import datetime

HOME = os.path.expanduser("~")
CREDS = os.path.join(HOME, ".claude", ".credentials.json")
CLAUDE_JSON = os.path.join(HOME, ".claude.json")
CACHE = os.path.join(HOME, ".claude", "statusline_cache.json")
SNAP_DIR = os.path.join(HOME, ".claude", "account-snapshots")


def _kst_now():
    tz = datetime.timezone(datetime.timedelta(hours=9))
    return datetime.datetime.now(tz).strftime("%Y-%m-%d %H:%M KST")


def _current_account():
    try:
        d = json.load(open(CLAUDE_JSON))
        return (d.get("oauthAccount") or {}).get("emailAddress")
    except Exception:
        return None


def _chmod600(p):
    os.chmod(p, stat.S_IRUSR | stat.S_IWUSR)


def cmd_current():
    acct = _current_account()
    print(acct or "(unknown)")
    return 0


def cmd_list():
    cur = _current_account()
    print("현재 로그인: {}".format(cur or "(unknown)"))
    if not os.path.isdir(SNAP_DIR):
        print("스냅샷 없음. 'claude-account-switch snapshot <label>' 로 저장.")
        return 0
    labels = sorted(d for d in os.listdir(SNAP_DIR)
                    if os.path.isdir(os.path.join(SNAP_DIR, d)))
    if not labels:
        print("스냅샷 없음.")
        return 0
    print("스냅샷:")
    for lb in labels:
        meta_p = os.path.join(SNAP_DIR, lb, "meta.json")
        email, ts = "?", "?"
        try:
            m = json.load(open(meta_p))
            email, ts = m.get("email", "?"), m.get("saved_at", "?")
        except Exception:
            pass
        mark = " <- 현재" if email == cur else ""
        print("  {:12s} {}  ({}){}".format(lb, email, ts, mark))
    return 0


def cmd_snapshot(label):
    if not label:
        print("사용법: claude-account-switch snapshot <label>", file=sys.stderr)
        return 2
    if not os.path.exists(CREDS):
        print("자격증명 없음: {} — 먼저 로그인하라.".format(CREDS), file=sys.stderr)
        return 1
    acct = _current_account()
    if not acct:
        print("경고: 현재 oauthAccount 식별 불가. 그래도 진행한다.", file=sys.stderr)
    dst = os.path.join(SNAP_DIR, label)
    os.makedirs(dst, exist_ok=True)
    os.chmod(SNAP_DIR, stat.S_IRWXU)
    os.chmod(dst, stat.S_IRWXU)
    # 1) credentials 복사 (내용 안 읽음, 파일 복사만)
    shutil.copyfile(CREDS, os.path.join(dst, "credentials.json"))
    _chmod600(os.path.join(dst, "credentials.json"))
    # 2) oauthAccount 블록만 추출 저장
    try:
        cj = json.load(open(CLAUDE_JSON))
        oauth = cj.get("oauthAccount") or {}
    except Exception:
        oauth = {}
    with open(os.path.join(dst, "oauthAccount.json"), "w") as f:
        json.dump(oauth, f)
    _chmod600(os.path.join(dst, "oauthAccount.json"))
    # 3) meta
    with open(os.path.join(dst, "meta.json"), "w") as f:
        json.dump({"email": acct, "saved_at": _kst_now()}, f)
    _chmod600(os.path.join(dst, "meta.json"))
    print("스냅샷 저장: {} = {}".format(label, acct or "(unknown)"))
    return 0


def cmd_use(label):
    if not label:
        print("사용법: claude-account-switch use <label>", file=sys.stderr)
        return 2
    src = os.path.join(SNAP_DIR, label)
    src_creds = os.path.join(src, "credentials.json")
    src_oauth = os.path.join(src, "oauthAccount.json")
    if not os.path.exists(src_creds):
        print("스냅샷 없음: {}".format(label), file=sys.stderr)
        return 1
    cur = _current_account()
    # 0) 안전 백업: 현재 creds 를 .bak 으로
    if os.path.exists(CREDS):
        shutil.copyfile(CREDS, CREDS + ".switch.bak")
        _chmod600(CREDS + ".switch.bak")
    # 1) credentials 교체 (atomic: temp + rename)
    tmp = CREDS + ".tmp"
    shutil.copyfile(src_creds, tmp)
    _chmod600(tmp)
    os.replace(tmp, CREDS)
    # 2) ~/.claude.json 의 oauthAccount 만 교체 (나머지 상태 보존, atomic)
    try:
        oauth = json.load(open(src_oauth))
    except Exception:
        oauth = None
    if oauth:
        try:
            cj = json.load(open(CLAUDE_JSON))
        except Exception:
            cj = {}
        # 백업
        if os.path.exists(CLAUDE_JSON):
            shutil.copyfile(CLAUDE_JSON, CLAUDE_JSON + ".switch.bak")
        cj["oauthAccount"] = oauth
        tmpj = CLAUDE_JSON + ".tmp"
        with open(tmpj, "w") as f:
            json.dump(cj, f)
        os.replace(tmpj, CLAUDE_JSON)
    # 3) statusline 캐시 삭제 → 다음 렌더에서 새 계정 사용량으로 갱신
    try:
        os.remove(CACHE)
    except FileNotFoundError:
        pass
    new = _current_account()
    print("전환: {} -> {}".format(cur or "?", new or "?"))
    print("rate-limit-guard 가 계정 불일치를 자동 감지하므로 대화를 바로 이어가면")
    print("statusline 이 새 계정 사용량으로 갱신된다. 재로그인 불필요.")
    return 0


def main(argv):
    if len(argv) < 2:
        print(__doc__)
        return 0
    cmd = argv[1]
    arg = argv[2] if len(argv) > 2 else None
    if cmd == "current":
        return cmd_current()
    if cmd == "list":
        return cmd_list()
    if cmd == "snapshot":
        return cmd_snapshot(arg)
    if cmd == "use":
        return cmd_use(arg)
    print("알 수 없는 명령: {}".format(cmd), file=sys.stderr)
    print(__doc__)
    return 2


if __name__ == "__main__":
    sys.exit(main(sys.argv))
