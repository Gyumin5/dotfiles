#!/bin/bash
# rate-limit-recovery: 차단 → 해제 전환 감지 후 알림 (필요 시 userbot trigger).
# systemd timer가 5분마다 호출.
#
# 동작:
# - rate_limits 조회 (statusline_cache.json)
# - 이전 상태 (~/.claude/state/rate-limit-blocked.flag) 와 비교
# - 차단 → 해제 전환이고 큐 파일에 항목 있으면 → 텔레그램 알림 + (TODO: userbot trigger)
# - userbot 미도입 상태에서는 사용자가 아무 메시지나 보내면 큐 flush됨.

set -uo pipefail

THRESHOLD_5H=90
THRESHOLD_7D=99
CACHE=~/.claude/statusline_cache.json
QUEUE_DIR=~/.claude/state/rate-limit-queue
STATE_FLAG=~/.claude/state/rate-limit-blocked.flag
FALLBACK_TELEGRAM_ENV=~/test_claude/.claude/telegram/.env

[ -f "$CACHE" ] || exit 0

# rate-limits 조회 — used_percentage + resets_at 기반 시간 fallback.
# cache 가 stale 해도 now > resets_at 이면 이미 리셋된 것으로 간주.
INFO=$(python3 -c '
import json, time
try:
  d = json.load(open("'"$CACHE"'"))
  rl = d.get("rate_limits", {})
  fh = rl.get("five_hour", {}); sd = rl.get("seven_day", {})
  now = time.time()
  def effective(window):
    rt = window.get("resets_at")
    if rt and now > rt:
      return 0  # 이미 리셋. cache 값 무시.
    v = window.get("used_percentage")
    return int(v) if isinstance(v, (int, float)) else -1
  print("{}|{}".format(effective(fh), effective(sd)))
except: print("-1|-1")' 2>/dev/null)
PCT_5H=$(echo "$INFO" | cut -d'|' -f1)
PCT_7D=$(echo "$INFO" | cut -d'|' -f2)

CURRENTLY_BLOCKED=false
if [ "$PCT_5H" -ge "$THRESHOLD_5H" ] 2>/dev/null; then CURRENTLY_BLOCKED=true; fi
if [ "$PCT_7D" -ge "$THRESHOLD_7D" ] 2>/dev/null; then CURRENTLY_BLOCKED=true; fi

WAS_BLOCKED=false
[ -f "$STATE_FLAG" ] && WAS_BLOCKED=true

# 상태 갱신
mkdir -p "$(dirname "$STATE_FLAG")"
if [ "$CURRENTLY_BLOCKED" = true ]; then
    touch "$STATE_FLAG"
    exit 0
fi

# 현재 안 차단됨. 이전에도 안 차단됐으면 무시.
if [ "$WAS_BLOCKED" = false ]; then
    exit 0
fi

# 차단 → 해제 전환. flag 제거.
rm -f "$STATE_FLAG"
# bypass flag 자동 정리는 "진짜 리셋(used_percentage=0)" 인 경우에만.
# % 일시적 하락(92→89)에선 bypass 유지 — 사용자가 켜둔 의도가 살아있음.
CLEARED_BYPASS=""
TRUE_RESET=false
if [ "$PCT_5H" = "0" ] && [ "$PCT_7D" = "0" ]; then
    TRUE_RESET=true
elif [ "$PCT_5H" = "0" ] && [ "$PCT_7D" -lt "$THRESHOLD_7D" ] 2>/dev/null; then
    TRUE_RESET=true
fi
if [ "$TRUE_RESET" = true ]; then
    for bf in ~/.claude/state/rate-limit-bypass.flag ~/.claude/state/rate-limit-bypass-*.flag; do
        [ -f "$bf" ] || continue
        rm -f "$bf"
        CLEARED_BYPASS="${CLEARED_BYPASS}$(basename "$bf") "
    done
fi

# 알림은 컨트롤봇 한 채팅에 통합. 프로젝트 봇은 실제 대화만.
CONTROL_BOT_ENV=~/.claude/control-bot/.env
send_project_alert() {
    local proj="$1" cwd="$2" qcount="$3"
    [ -f "$CONTROL_BOT_ENV" ] || return 0
    ( . "$CONTROL_BOT_ENV"
      if [ -n "${CONTROL_BOT_TOKEN:-}" ]; then
          local bypass_note=""
          [ -n "$CLEARED_BYPASS" ] && bypass_note=" (bypass flag 자동 해제: ${CLEARED_BYPASS})"
          if [ "$qcount" -gt 0 ]; then
              msg="[${proj}] rate-limit 해제 (5h ${PCT_5H}%, 7d ${PCT_7D}%)${bypass_note}. 큐 ${qcount}개 대기. 아무 메시지나 보내면 자동 처리됨."
          else
              msg="[${proj}] rate-limit 해제 (5h ${PCT_5H}%, 7d ${PCT_7D}%)${bypass_note}. 큐 비어있음."
          fi
          curl -s -X POST "https://api.telegram.org/bot${CONTROL_BOT_TOKEN}/sendMessage" \
              --data-urlencode "chat_id=8689118207" \
              --data-urlencode "text=${msg}" >/dev/null 2>&1
      fi
    )
}

NOTIFIED=false
if [ -d "$QUEUE_DIR" ]; then
    # 큐 있는 프로젝트 우선
    for f in "$QUEUE_DIR"/*.jsonl; do
        [ -f "$f" ] || continue
        n=$(wc -l < "$f" 2>/dev/null || echo 0)
        proj=$(basename "$f" .jsonl)
        cwd_file="$QUEUE_DIR/${proj}.cwd"
        cwd=""
        [ -f "$cwd_file" ] && cwd=$(cat "$cwd_file")
        if [ "$n" -gt 0 ]; then
            send_project_alert "$proj" "$cwd" "$n"
            NOTIFIED=true
        fi
    done
fi

# 큐 있는 프로젝트가 하나도 없으면 컨트롤봇으로 일반 알림 1회.
if [ "$NOTIFIED" = false ] && [ -f "$CONTROL_BOT_ENV" ]; then
    . "$CONTROL_BOT_ENV"
    if [ -n "${CONTROL_BOT_TOKEN:-}" ]; then
        msg="rate-limit 해제 (5h ${PCT_5H}%, 7d ${PCT_7D}%). 큐 비어있음."
        curl -s -X POST "https://api.telegram.org/bot${CONTROL_BOT_TOKEN}/sendMessage" \
            --data-urlencode "chat_id=8689118207" \
            --data-urlencode "text=${msg}" >/dev/null 2>&1
    fi
fi

# TODO: userbot 도입 후 — 큐 있으면 userbot으로 "trigger:queue-flush" 메시지 자동 전송.
# 현재는 사용자 다음 메시지가 트리거 역할.
# 예시 (userbot 도입 시):
#   if [ "$TOTAL_QUEUED" -gt 0 ]; then
#       for f in "$QUEUE_DIR"/*.jsonl; do
#           proj=$(basename "$f" .jsonl)
#           ~/.local/share/userbot/.venv/bin/python ~/.local/share/userbot/send_trigger.py "$proj"
#       done
#   fi

exit 0
