#!/bin/bash
# rate-limit-recovery: 차단 → 해제 전환 감지 후 알림 (필요 시 userbot trigger).
# systemd timer가 5분마다 호출.
#
# 동작:
# - rate_limits 조회 (statusline_cache.json)
# - 이전 상태 (~/.claude/state/rate-limit-blocked.flag) 와 비교
# - 차단 → 해제 전환이고 큐 파일에 항목 있으면 → 텔레그램 알림 + (TODO: userbot trigger)
# - userbot 미도입 상태에서는 사용자가 아무 메시지나 보내면 큐 flush됨.

set -uo pipefail

THRESHOLD_5H=90
THRESHOLD_7D=99
CACHE=~/.claude/statusline_cache.json
QUEUE_DIR=~/.claude/state/rate-limit-queue
STATE_FLAG=~/.claude/state/rate-limit-blocked.flag
FALLBACK_TELEGRAM_ENV=~/dotfiles/.claude/telegram/.env
# userbot 자동 재개: 큐 있는 세션 봇에 trigger:queue-flush 발송 → prompt-guard 가 큐 처리.
USERBOT_SEND="$HOME/.local/bin/claude-userbot-send"
USERBOT_SESSION="$HOME/.claude/userbot/userbot.session"
# raion 처럼 유저봇이 없는 PC 는 relay.conf 의 USERBOT_HOST 로 home 에 ssh 위임.
RELAY_CONF="$HOME/.claude/userbot/relay.conf"

[ -f "$CACHE" ] || exit 0

# rate-limits 조회 — used_percentage + resets_at 기반 시간 fallback.
# cache 가 stale 해도 now > resets_at 이면 이미 리셋된 것으로 간주.
INFO=$(python3 -c '
import json, time
try:
  d = json.load(open("'"$CACHE"'"))
  rl = d.get("rate_limits", {})
  fh = rl.get("five_hour", {}); sd = rl.get("seven_day", {})
  now = time.time()
  def effective(window):
    rt = window.get("resets_at")
    if rt and now > rt:
      return 0  # 이미 리셋. cache 값 무시.
    v = window.get("used_percentage")
    return int(v) if isinstance(v, (int, float)) else -1
  print("{}|{}".format(effective(fh), effective(sd)))
except: print("-1|-1")' 2>/dev/null)
PCT_5H=$(echo "$INFO" | cut -d'|' -f1)
PCT_7D=$(echo "$INFO" | cut -d'|' -f2)

CURRENTLY_BLOCKED=false
if [ "$PCT_5H" -ge "$THRESHOLD_5H" ] 2>/dev/null; then CURRENTLY_BLOCKED=true; fi
if [ "$PCT_7D" -ge "$THRESHOLD_7D" ] 2>/dev/null; then CURRENTLY_BLOCKED=true; fi

WAS_BLOCKED=false
[ -f "$STATE_FLAG" ] && WAS_BLOCKED=true

# 상태 갱신
mkdir -p "$(dirname "$STATE_FLAG")"
if [ "$CURRENTLY_BLOCKED" = true ]; then
    touch "$STATE_FLAG"
    exit 0
fi

# 현재 안 차단됨. 이전에도 안 차단됐으면 무시.
if [ "$WAS_BLOCKED" = false ]; then
    exit 0
fi

# 차단 → 해제 전환. flag 제거.
rm -f "$STATE_FLAG"
# bypass flag 자동 정리는 "진짜 리셋(used_percentage=0)" 인 경우에만.
# % 일시적 하락(92→89)에선 bypass 유지 — 사용자가 켜둔 의도가 살아있음.
CLEARED_BYPASS=""
TRUE_RESET=false
if [ "$PCT_5H" = "0" ] && [ "$PCT_7D" = "0" ]; then
    TRUE_RESET=true
elif [ "$PCT_5H" = "0" ] && [ "$PCT_7D" -lt "$THRESHOLD_7D" ] 2>/dev/null; then
    TRUE_RESET=true
fi
if [ "$TRUE_RESET" = true ]; then
    for bf in ~/.claude/state/rate-limit-bypass.flag ~/.claude/state/rate-limit-bypass-*.flag; do
        [ -f "$bf" ] || continue
        rm -f "$bf"
        CLEARED_BYPASS="${CLEARED_BYPASS}$(basename "$bf") "
    done
fi

# 프로젝트의 telegram .env 경로 해석. 없으면 fallback. stdout 으로 경로 출력.
resolve_env_file() {
    local proj="$1" cwd="$2" env_file=""
    if [ -n "$cwd" ] && [ -f "${cwd}/.claude/telegram/.env" ]; then
        env_file="${cwd}/.claude/telegram/.env"
    else
        for cand in ~/${proj} ~/mon/${proj} ~/av-ros/test/${proj} ~/av-ros/${proj}; do
            if [ -f "${cand}/.claude/telegram/.env" ]; then
                env_file="${cand}/.claude/telegram/.env"
                break
            fi
        done
    fi
    [ -f "$env_file" ] || env_file="$FALLBACK_TELEGRAM_ENV"
    echo "$env_file"
}

# 해당 봇의 @username 을 getMe 로 조회 (토큰은 이 PC 에 머물고 username 만 반환).
resolve_bot_username() {
    local env_file="$1"
    [ -f "$env_file" ] || return 1
    ( . "$env_file"
      [ -n "${TELEGRAM_BOT_TOKEN:-}" ] || exit 1
      curl -s --max-time 8 "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getMe" \
        | python3 -c 'import json,sys
try:
  u=json.load(sys.stdin)["result"]["username"]
  print("@"+u)
except: sys.exit(1)' ) 2>/dev/null
}

# 큐 자동 재개 trigger 발송. 성공 0, 실패 1.
# 세션 이름이 아니라 그 PC 가 자기 .env 에서 알아낸 봇 @username 으로 보냄
# → home/raion 세션 이름 충돌(둘 다 'dotfiles') 원천 차단.
# 1) 로컬 유저봇 (home) → claude-userbot-send <@bot> 직접.
# 2) 유저봇 없는 PC (raion) → relay.conf USERBOT_HOST 로 home 유저봇에 ssh 위임.
trigger_flush() {
    local env_file="$1" botuser=""
    botuser=$(resolve_bot_username "$env_file")
    [ -n "$botuser" ] || return 1
    # --delete-after 8: 세션이 getUpdates 로 받은 뒤 trigger 메시지 삭제 → 채팅 노이즈 제거.
    if [ -x "$USERBOT_SEND" ] && [ -f "$USERBOT_SESSION" ]; then
        "$USERBOT_SEND" --delete-after 8 "$botuser" "trigger:queue-flush" >/dev/null 2>&1 && return 0
        return 1
    fi
    if [ -f "$RELAY_CONF" ]; then
        # shellcheck disable=SC1090
        . "$RELAY_CONF"
        if [ -n "${USERBOT_HOST:-}" ]; then
            # 비대화형 ssh 는 ~/.local/bin 이 PATH 에 없으므로 절대경로(~remote 확장).
            ssh -o BatchMode=yes -o ConnectTimeout=20 "$USERBOT_HOST" \
                "~/.local/bin/claude-userbot-send --delete-after 8 '${botuser}' 'trigger:queue-flush'" >/dev/null 2>&1 && return 0
        fi
    fi
    return 1
}

# 알림은 각 프로젝트 봇 채팅으로 송신 (사용자: 각 세션 알림은 그 세션 봇으로).
send_project_alert() {
    local proj="$1" env_file="$2" qcount="$3" triggered="${4:-false}"
    [ -f "$env_file" ] || return 0
    ( . "$env_file"
      if [ -n "${TELEGRAM_BOT_TOKEN:-}" ]; then
          local bypass_note=""
          [ -n "$CLEARED_BYPASS" ] && bypass_note=" (bypass flag 자동 해제: ${CLEARED_BYPASS})"
          if [ "$qcount" -gt 0 ] && [ "$triggered" = true ]; then
              msg="rate-limit 해제 (5h ${PCT_5H}%, 7d ${PCT_7D}%)${bypass_note}. 큐 ${qcount}개 자동 재개 중 (유저봇 trigger 발송)."
          elif [ "$qcount" -gt 0 ]; then
              msg="rate-limit 해제 (5h ${PCT_5H}%, 7d ${PCT_7D}%)${bypass_note}. 큐 ${qcount}개 대기. 아무 메시지나 보내면 자동 처리됨."
          else
              msg="rate-limit 해제 (5h ${PCT_5H}%, 7d ${PCT_7D}%)${bypass_note}. 큐 비어있음."
          fi
          curl -s -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage" \
              --data-urlencode "chat_id=8689118207" \
              --data-urlencode "text=${msg}" >/dev/null 2>&1
      fi
    )
}

NOTIFIED=false
if [ -d "$QUEUE_DIR" ]; then
    # 큐 있는 프로젝트 우선
    for f in "$QUEUE_DIR"/*.jsonl; do
        [ -f "$f" ] || continue
        n=$(wc -l < "$f" 2>/dev/null || echo 0)
        proj=$(basename "$f" .jsonl)
        cwd_file="$QUEUE_DIR/${proj}.cwd"
        cwd=""
        [ -f "$cwd_file" ] && cwd=$(cat "$cwd_file")
        if [ "$n" -gt 0 ]; then
            env_file=$(resolve_env_file "$proj" "$cwd")
            TRIGGERED=false
            if trigger_flush "$env_file"; then
                TRIGGERED=true
            fi
            send_project_alert "$proj" "$env_file" "$n" "$TRIGGERED"
            NOTIFIED=true
        fi
    done
fi

# 큐 비어있어도 해제 사실은 컨트롤봇 한 채팅에 1회 표시 (모든 프로젝트 알림 분산되어
# 어디서도 안 받으면 사용자가 해제 시각 모를 수 있음). 큐 있는 프로젝트별 알림과 별개.
CONTROL_BOT_ENV=~/.claude/control-bot/.env
if [ "$NOTIFIED" = false ] && [ -f "$CONTROL_BOT_ENV" ]; then
    . "$CONTROL_BOT_ENV"
    if [ -n "${CONTROL_BOT_TOKEN:-}" ]; then
        msg="rate-limit 해제 (5h ${PCT_5H}%, 7d ${PCT_7D}%). 큐 비어있음."
        curl -s -X POST "https://api.telegram.org/bot${CONTROL_BOT_TOKEN}/sendMessage" \
            --data-urlencode "chat_id=8689118207" \
            --data-urlencode "text=${msg}" >/dev/null 2>&1
    fi
fi

# userbot 자동 재개는 위 큐 루프의 trigger_flush() 로 처리됨 (2026-06-02).
# - home: claude-userbot-send --session <proj> "trigger:queue-flush" 직접.
# - raion: relay.conf USERBOT_HOST 로 home 에 ssh 위임.
# trigger 실패 시(유저봇 미설치/세션 만료) 기존 폴백 — 사용자 다음 메시지가 트리거.

exit 0
