RUN_BASE = Path.home() / ".claude" / "state" / "ai-debate"
CACHE_DIR = RUN_BASE / "cache"
CACHE_TTL_SEC = 24 * 3600

# 동적 다역할 시스템 (2026-05-12, arbiter 합의 run-20260512T053815Z).
# critic 항상 강제 포함. integrator는 arbiter와 책임 중복으로 제외.
ROLE_REGISTRY = {
    "debater": {
        "instructions": (
            "당신은 토론자(debater). 주어진 task에 대해 자신의 의견을 제시하라. "
            "구체 근거(evidence)와 검증 방법(verification)을 포함하라. confidence는 0.0~1.0. "
            "이전 라운드 출력이 있어도 다수 의견에 영합하지 마라 — 근거로만 입장을 바꿔라. "
            "reconciliation 라운드 지시가 있으면 position_changed_reason(입장 유지/변경 사유), "
            "remaining_dissent(남은 반대의견), refutation_condition(내 입장이 틀렸다고 인정할 조건)을 채워라(그 외엔 생략)."
        ),
        "schema": ["position", "reasoning", "evidence", "verification", "confidence",
