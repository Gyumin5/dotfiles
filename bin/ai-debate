    "minority_survived",
]


def now_iso():
    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")


def project_memory():
    cwd = Path.cwd()
    proj_key = "-home-gmoh-" + cwd.name
    mem_dir = Path.home() / ".claude" / "projects" / proj_key / "memory"
    if not mem_dir.is_dir():
        return ""
    parts = []
    for f in sorted(mem_dir.glob("*.md")):
        if f.name == "MEMORY.md":
            continue
        try:
            parts.append(f.read_text(encoding="utf-8", errors="replace"))
        except Exception:
            pass
    return "\n---\n".join(parts)


def role_prompt(role, task, memory_block, prior_block, round_idx=None, is_final_round=False):
    schema_keys = SCHEMAS[role]
    if role in ROLE_REGISTRY:
        instructions = ROLE_REGISTRY[role]["instructions"]
    elif role == "arbiter":
        instructions = (
            "당신은 아비터(arbiter). 모든 역할·라운드 출력을 받아 최종 결정을 내려라. "
            "action_steps는 실행 가능한 단계, verification_plan은 결정이 옳았는지 확인하는 방법. "
            "delegation_target은 이 결정을 실제로 수행할 주체 (self·Claude·codex·gemini·human·subagent 중 하나, 단순 결정 정리면 'none'). "
            "stop_condition은 이 작업을 언제 중단/완료해야 하는지. "
            "역할별 합의/이견을 통합하되 per-agent(codex/gemini/claude) 라벨링은 출력하지 말 것. "
            "risks(주요 위험 목록), open_questions(미해결 질문), role_coverage(어느 역할이 어떤 기여를 했는지 요약, 에이전트 이름 없이), "
            "call_budget_used(예: '12/24'), dissent(채택 안 된 의견)을 채워라. "
            "입력에 [ROUND1 독립 입장]과 [MINORITY REPORT]가 별도로 주어진다. 후속 라운드의 수렴 결과만 보지 말고, "
            "round1 원본 입장과 소수의견이 옳았을 가능성을 반드시 점검해서 결론에 반영하라. "
            "minority_survived 에는 round1 소수의견이 최종 결론에 살아남았는지/검토 후 기각됐다면 그 사유를 한 줄로 적어라. "
            "동적 역할이 아닌 경우(debater+critic만) risks/open_questions/role_coverage/call_budget_used는 빈 값 또는 생략 가능."
        )
    else:
        # 알 수 없는 역할 — fallback
        instructions = f"역할: {role}. 주어진 task에 답하라."

    # reconciliation 라운드(마지막 라운드)의 debater: 새 주장 대신 입장 정리 + 소수의견 보존.
    if role == "debater" and is_final_round:
        instructions = instructions + (
            "\n\n[reconciliation 라운드 — 마지막] 새 주장·새 논거 추가 금지. 다음만 정리하라: "
            "position_changed_reason(round1 입장 유지/변경 사유), 받아들인 새 근거, "
            "remaining_dissent(끝까지 남은 반대의견), refutation_condition(내 입장이 틀렸다고 인정할 조건). "
            "다수에 영합하지 말고 round1 입장과 지금 입장의 차이를 분명히 밝혀라."
        )

    parts = [f"역할: {role}", "", instructions, ""]
    if memory_block:
        parts.append("[Project Memory]")
        parts.append(memory_block[:6000])
        parts.append("")
    parts.append("[task]")
    parts.append(task)
    parts.append("")
    if prior_block:
        parts.append(prior_block)
        parts.append("")
    parts.append("출력은 반드시 다음 JSON 스키마로만:")
    parts.append(json.dumps({k: "<value>" for k in schema_keys}, ensure_ascii=False, indent=2))
    parts.append("JSON 외 텍스트, 백틱, 코드펜스 금지. 한국어 평문.")
    return "\n".join(parts)


def parse_json_loose(text):
    """Balanced-brace 스캐너. 후보 중 스키마 키 매칭이 가장 많은 것 반환."""
    if not text:
        return None
    text = re.sub(r"```(?:json)?", "", text)
    schema_keys = set()
    for keys in SCHEMAS.values():
        schema_keys.update(keys)
    candidates = []
    n = len(text)
    i = 0
    while i < n:
        if text[i] == "{":
            depth = 0
            in_str = False
            esc = False
            j = i
            while j < n:
                c = text[j]
                if in_str:
                    if esc:
                        esc = False
                    elif c == "\\":
                        esc = True
                    elif c == '"':
                        in_str = False
                else:
                    if c == '"':
                        in_str = True
                    elif c == "{":
                        depth += 1
                    elif c == "}":
                        depth -= 1
                        if depth == 0:
                            blob = text[i:j + 1]
                            try:
                                obj = json.loads(blob)
                            except json.JSONDecodeError:
                                blob2 = re.sub(r",(\s*[}\]])", r"\1", blob)
                                try:
                                    obj = json.loads(blob2)
                                except json.JSONDecodeError:
                                    obj = None
                            if isinstance(obj, dict):
                                candidates.append(obj)
                            break
                j += 1
            i = j + 1
        else:
            i += 1
    if not candidates:
        return None
    candidates.sort(key=lambda o: len(set(o.keys()) & schema_keys), reverse=True)
    return candidates[0]


def call_agent(agent, role, prompt, run_dir, label):
    raw_path = run_dir / f"{label}.raw.txt"
    prompt_path = run_dir / f"{label}.prompt.txt"
    prompt_path.write_text(prompt, encoding="utf-8")
    started = time.time()
    try:
        if agent == "gemini":
            # 2026-05-21: gemini-cli (EOL 2026-06-18) → antigravity CLI (agy) 교체.
            # agy -p "..." + stdin=prompt 패턴. --print-timeout 으로 hang 회피.
            cmd = ["/home/gmoh/.local/bin/agy", "-p", "위 지시대로 JSON만 출력", "--print-timeout", "5m"]
            env = os.environ.copy()
            env["AI_OUT_RAW"] = "1"
        elif agent == "codex":
            cmd = ["codex-ask", "--new", "위 지시대로 JSON만 출력"]
            env = os.environ.copy()
            env["AI_OUT_RAW"] = "1"
        elif agent == "claude":
            # 격리 HOME으로 부모 세션 plugin sync 충돌 회피. prompt 본문에 schema 강제 포함.
            cmd = ["/home/gmoh/.local/bin/claude", "-p", prompt]
            env = {
                "HOME": CLAUDE_ISO_HOME,
                "XDG_CONFIG_HOME": f"{CLAUDE_ISO_HOME}/.config",
                "XDG_DATA_HOME": f"{CLAUDE_ISO_HOME}/.local/share",
                "XDG_STATE_HOME": f"{CLAUDE_ISO_HOME}/.local/state",
                "PATH": "/home/gmoh/.local/bin:/usr/local/bin:/usr/bin:/bin",
                "TERM": "dumb",
            }
            # claude는 stdin 안 받음 — prompt를 -p 인자로 직접 전달
            proc = subprocess.run(
                cmd, capture_output=True, text=True,
                timeout=TIMEOUT, env=env, cwd="/tmp",
            )
            raw = proc.stdout + ("\n[stderr]\n" + proc.stderr if proc.stderr.strip() else "")
            raw_path.write_text(raw, encoding="utf-8")
            if proc.returncode != 0:
                return {"_error": f"{agent} exit {proc.returncode}", "_duration": round(time.time() - started, 2), "_agent": agent, "_role": role}
            parsed = parse_json_loose(proc.stdout)
            if parsed is None:
                return {"_error": f"{agent} JSON parse failed", "_raw": proc.stdout[:300], "_duration": round(time.time() - started, 2), "_agent": agent, "_role": role}
            parsed["_agent"] = agent
            parsed["_role"] = role
            parsed["_duration"] = round(time.time() - started, 2)
            norm_path = run_dir / f"{label}.normalized.json"
            norm_path.write_text(json.dumps(parsed, ensure_ascii=False, indent=2), encoding="utf-8")
            return parsed
        else:
            return {"_error": f"unknown agent {agent}", "_duration": 0, "_agent": agent, "_role": role}
        proc = subprocess.run(
            cmd, input=prompt, capture_output=True, text=True,
            timeout=TIMEOUT, env=env,
        )
        raw = proc.stdout + ("\n[stderr]\n" + proc.stderr if proc.stderr.strip() else "")
        raw_path.write_text(raw, encoding="utf-8")
        if proc.returncode != 0:
            return {"_error": f"{agent} exit {proc.returncode}", "_duration": round(time.time() - started, 2), "_agent": agent, "_role": role}
    except subprocess.TimeoutExpired:
        return {"_error": f"{agent} timeout", "_duration": round(time.time() - started, 2), "_agent": agent, "_role": role}
    except Exception as e:
        return {"_error": f"{agent} {e}", "_duration": round(time.time() - started, 2), "_agent": agent, "_role": role}

    parsed = parse_json_loose(proc.stdout)
    if parsed is None:
        return {"_error": f"{agent} JSON parse failed", "_raw": proc.stdout[:300], "_duration": round(time.time() - started, 2), "_agent": agent, "_role": role}
    parsed["_agent"] = agent
    parsed["_role"] = role
    parsed["_duration"] = round(time.time() - started, 2)
    norm_path = run_dir / f"{label}.normalized.json"
    norm_path.write_text(json.dumps(parsed, ensure_ascii=False, indent=2), encoding="utf-8")
    return parsed


def consensus_reached(round_outputs):
    """비판자 모두 should_proceed=true이고 debater들 position이 수렴하면 합의."""
    debs = [o for o in round_outputs if o.get("_role") == "debater" and "_error" not in o]
    crits = [o for o in round_outputs if o.get("_role") == "critic" and "_error" not in o]
    if not debs or not crits:
        return False

    def truthy(v):
        if isinstance(v, bool):
            return v
        if isinstance(v, str):
            return v.strip().lower() in ("true", "yes", "예", "y", "1")
        return False

    if not all(truthy(c.get("should_proceed")) for c in crits):
        return False

    if len(debs) < 2:
        # debater 1명뿐이면 critic 통과로만 합의 인정
        return True

    # 모든 debater 쌍의 position 자카드 평균이 0.5 이상이면 수렴
    from itertools import combinations
    sets = [set((d.get("position", "") or "").lower().split()) for d in debs]
    pairs = list(combinations(range(len(sets)), 2))
    if not pairs:
        return True
    jaccards = [
        len(sets[a] & sets[b]) / max(len(sets[a] | sets[b]), 1)
        for a, b in pairs
    ]
    return sum(jaccards) / len(jaccards) >= 0.5


def escalation_triggered(round_outputs):
    """--deep adaptive 4~5라운드 트리거: critic should_proceed 분기(핵심 위험 미해결) 또는
    debater 평균 confidence < 0.6(저신뢰). 둘 중 하나면 확장. (2026-06-04)"""
    crits = [o for o in round_outputs if o.get("_role") == "critic" and "_error" not in o]
    debs = [o for o in round_outputs if o.get("_role") == "debater" and "_error" not in o]
    sp = [_truthy_sp(c.get("should_proceed")) for c in crits]
    if sp and any(sp) and not all(sp):
        return True  # critic 간 판정 분기 = 미해결 위험
    confs = []
    for d in debs:
        try:
            confs.append(float(d.get("confidence")))
        except (TypeError, ValueError):
            pass
    if confs and (sum(confs) / len(confs)) < 0.6:
        return True
    return False


def build_prior_block(prior_outputs):
    if not prior_outputs:
        return ""
    summary = []
    for o in prior_outputs:
        if "_error" in o:
            continue
        rnd = o.get("_round", "?")
        agent = o.get("_agent", "?")
        role = o.get("_role", "?")
        keys = SCHEMAS.get(role, [])
        compact = {k: o.get(k) for k in keys if o.get(k) is not None}
        summary.append({"round": rnd, "agent": agent, "role": role, **compact})
    return "[이전 라운드 출력]\n" + json.dumps(summary, ensure_ascii=False, indent=2)[:10000]


def run_round(round_idx, task, memory_block, prior_outputs, run_dir, skip_agents=None, roles=None, is_final_round=False):
    """skip_agents: 이전 라운드에서 실패한 provider 제외. roles: None이면 ROLES 기본.
    is_final_round: 마지막 라운드면 debater 를 reconciliation 모드로. round1 은 prior 없어 자동 독립."""
    prior_block = build_prior_block(prior_outputs)
    skip_agents = skip_agents or set()
    active_pool = [a for a in POOL if a not in skip_agents]
    if not active_pool:
        active_pool = POOL
    roles = roles or ROLES
    tasks = []
    for agent in active_pool:
        for role in roles:
            label = f"r{round_idx}.{role}.{agent}"
            prompt = role_prompt(role, task, memory_block, prior_block, round_idx=round_idx, is_final_round=is_final_round)
            tasks.append((agent, role, prompt, label))

    outputs = []
    with ThreadPoolExecutor(max_workers=len(tasks)) as ex:
        futures = {ex.submit(call_agent, a, r, p, run_dir, l): (a, r) for (a, r, p, l) in tasks}
        for f in as_completed(futures):
            o = f.result()
            o["_round"] = round_idx
            outputs.append(o)
    return outputs


def _truthy_sp(v):
    if isinstance(v, bool):
        return v
    if isinstance(v, str):
        return v.strip().lower() in ("true", "yes", "예", "y", "1")
    return False


def build_arbiter_block(all_outputs):
    """arbiter 입력: 전체 prior + round1 독립 원본 + minority report 를 별도 섹션으로.
    후속 라운드 수렴에 묻힌 소수의견을 arbiter 가 반드시 다시 보게 한다(2026-06-04 anti-conformity)."""
    full = build_prior_block(all_outputs)
    r1 = [o for o in all_outputs if o.get("_round") == 1 and "_error" not in o]
    r1_compact = []
    for o in r1:
        role = o.get("_role", "?")
        keys = SCHEMAS.get(role, [])
        compact = {k: o.get(k) for k in keys if o.get(k) is not None}
        r1_compact.append({"agent": o.get("_agent"), "role": role, **compact})
    deb_positions = [{"agent": o.get("_agent"), "position": o.get("position")}
                     for o in r1 if o.get("_role") == "debater"]
    minority = [{"agent": o.get("_agent"), "missed_risks": o.get("missed_risks"),
                 "reasoning": o.get("reasoning")}
                for o in r1 if o.get("_role") == "critic" and not _truthy_sp(o.get("should_proceed"))]
    parts = [full, "",
             "[ROUND1 독립 입장 — 앵커링 없이 생성된 원본. 후속 수렴에 묻지 말고 반드시 재검토]",
             json.dumps(r1_compact, ensure_ascii=False, indent=2)[:6000]]
    if deb_positions:
        parts += ["", "[ROUND1 debater 입장 목록 — 소수의견 점검용]",
                  json.dumps(deb_positions, ensure_ascii=False, indent=2)[:3000]]
    if minority:
        parts += ["", "[MINORITY REPORT — round1 비판자 반대/미해결 위험. 기각하려면 사유 명시]",
                  json.dumps(minority, ensure_ascii=False, indent=2)[:3000]]
    return "\n".join(parts)


def run_arbiter(task, memory_block, all_outputs, run_dir):
    prior_block = build_arbiter_block(all_outputs)
    prompt = role_prompt("arbiter", task, memory_block, prior_block)
    out = call_agent("codex", "arbiter", prompt, run_dir, "arbiter")
    return out


def run_planner(task, max_roles, run_dir):
    """auto-roles: codex가 ROLE_REGISTRY 안에서 필요한 역할 N개(≤max_roles) 선정.
    critic은 호출 측이 강제 추가하므로 planner는 제외해도 됨. 실패 시 [debater]만 반환."""
    available = [r for r in ROLE_REGISTRY.keys() if r != "critic"]
    instr = (
        "당신은 역할 플래너. 주어진 task에 대해 ai-debate 다역할 토론에서 사용할 역할을 "
        f"아래 목록에서만 최대 {max_roles}개 선택하라. 불확실하면 [debater]만 선택. "
        "critic은 자동 강제 추가되므로 선택할 필요 없음. integrator는 사용 금지(arbiter와 중복).\n"
        f"가능한 역할: {', '.join(available)}\n"
        "출력은 다음 JSON만:\n"
        '{"roles": ["debater", ...], "reasoning": "<짧게>"}'
    )
    prompt = instr + "\n\n[task]\n" + task
    label = "planner"
    raw_path = run_dir / f"{label}.raw.txt"
    prompt_path = run_dir / f"{label}.prompt.txt"
    prompt_path.write_text(prompt, encoding="utf-8")
    try:
        proc = subprocess.run(
            ["codex-ask", "--new", "위 지시대로 JSON만 출력"],
            input=prompt, capture_output=True, text=True,
            timeout=TIMEOUT, env={**os.environ, "AI_OUT_RAW": "1"},
        )
        raw_path.write_text(proc.stdout + ("\n[stderr]\n" + proc.stderr if proc.stderr.strip() else ""),
                            encoding="utf-8")
        if proc.returncode != 0:
            return ["debater"]
        obj = parse_json_loose(proc.stdout)
        if not obj or "roles" not in obj:
            return ["debater"]
        picked = [r for r in obj["roles"] if r in ROLE_REGISTRY and r != "critic"]
        if not picked:
            return ["debater"]
        return picked[:max_roles]
    except Exception:
        return ["debater"]


def select_roles(task, args, run_dir):
    """반환: (roles 리스트, source 라벨). critic은 항상 끝에 추가."""
    explicit = (args.roles or "").strip()
    if explicit:
        items = [r.strip() for r in explicit.split(",") if r.strip()]
        unknown = [r for r in items if r not in ROLE_REGISTRY]
        if unknown:
            print(f"ERROR: 알 수 없는 역할: {unknown}. 가능: {list(ROLE_REGISTRY.keys())}", file=sys.stderr)
            sys.exit(2)
        roles = [r for r in items if r != "critic"]
        if "critic" not in roles:
            roles.append("critic")
        return roles, "explicit"
    if args.auto_roles:
        picked = run_planner(task, args.max_roles, run_dir)
        roles = [r for r in picked if r != "critic"]
        if "critic" not in roles:
            roles.append("critic")
        return roles[:args.max_roles + 1], "auto"  # +1 for critic
    # 무옵션: 기존 호환 — debater+critic 그대로
    return ["debater", "critic"], "default"


# --- PROVIDER 헬스 진단 (2026-06-08) ---
# arbiter(codex)가 죽어도 떠야 하므로 per-provider raw 파일을 독립 스캔한다.
# 어느 AI가 / 왜 / 해결법을 사람이 바로 알 수 있게 결과에 같이 출력.
import re as _re_health

_HEALTH_SIGS = [
    (r"invalid_grant|reauth|re-?authenticate|not logged in|로그인 필요|unauthor|\b401\b|403\b|permission denied",
     "인증 만료/실패", "REAUTH"),
    (r"authentication timed out|auth[^\n]{0,20}tim(e|ed)\s?out",
     "인증 타임아웃", "REAUTH"),
    (r"\b429\b|RESOURCE_EXHAUSTED|quota|rate.?limit|too many requests",
     "쿼터/레이트리밋", "쿼터·레이트리밋 — 잠시 후 재시도(공유 계정 한도 가능)."),
    (r"tim(e|ed)\s?out|timeout|deadline exceeded",
     "타임아웃", "네트워크/일시 hang — 재시도, 반복되면 재인증."),
    (r"JSON parse failed|could not parse|parse error",
     "출력 파싱 실패", "JSON 아닌 출력 — 일시 이상, 재시도."),
]
_REAUTH_FIX = {
    "gemini": "gemini(agy/antigravity) 재인증: 터미널에서 재로그인. invalid_grant 면 ~/.config/gcloud 잔재 정리 후 재로그인.",
    "codex": "codex 재로그인 필요(codex CLI 재인증). ※ arbiter=codex — codex 죽으면 최종 정리(아비터) 불가하니 우선 복구.",
    "claude": "claude(격리 HOME /home/gmoh/.claude-iso) 인증/플러그인 점검.",
}


def _scan_raw_for_cause(run_dir, agent):
    """해당 agent 의 모든 raw 파일을 합쳐 첫 매칭 시그니처 반환. (label, fix) 또는 None."""
    import glob as _glob
    texts = []
    pats = [str(run_dir / f"*.{agent}.raw.txt")]
    if agent == "codex":
        pats.append(str(run_dir / "arbiter.raw.txt"))
        pats.append(str(run_dir / "planner.raw.txt"))
    for pat in pats:
        for fp in _glob.glob(pat):
            try:
                texts.append(open(fp, encoding="utf-8", errors="ignore").read())
            except Exception:
                pass
    blob = "\n".join(texts)
    if not blob.strip():
        return None
    for rx, label, fix in _HEALTH_SIGS:
        if _re_health.search(rx, blob, _re_health.IGNORECASE):
            resolved = _REAUTH_FIX.get(agent, "재인증/재시도 필요.") if fix == "REAUTH" else fix
            return (label, resolved)
    return None


def provider_health_lines(run_dir, all_outputs, arb=None):
    """provider별 ok/fail + 실패 원인·해결법. 문제 있을 때만 라인 반환."""
    stats = {}
    for o in all_outputs:
        a = o.get("_agent")
        if not a or a == "arbiter":
            continue
        s = stats.setdefault(a, [0, 0])
        s[1 if "_error" in o else 0] += 1
    lines = []
    for agent in sorted(stats):
        ok, fail = stats[agent]
        if fail == 0:
            continue
        cause = _scan_raw_for_cause(run_dir, agent)
        if cause:
            label, fix = cause
            lines.append(f"  {agent}: {label} ({ok}ok/{fail}fail) → {fix}")
        else:
            lines.append(f"  {agent}: 실패 ({ok}ok/{fail}fail) 원인 불명 → raw 확인: {run_dir}/*.{agent}.raw.txt")
    # arbiter(codex) 별도 강조
    if arb is not None and isinstance(arb, dict) and "_error" in arb:
        cause = _scan_raw_for_cause(run_dir, "codex")
        fix = cause[1] if cause else _REAUTH_FIX["codex"]
        lab = cause[0] if cause else arb.get("_error", "실패")
        lines.append(f"  ARBITER(codex): {lab} → {fix}")
    if lines:
        return ["[PROVIDER 헬스] 일부 AI 실패 — 원인·해결:"] + lines
    return []


def main():
    ap = argparse.ArgumentParser(description="ai-debate: 멀티 AI 합의 토론")
    ap.add_argument("task", help="토론할 task")
    ap.add_argument("--max-rounds", type=int, default=2, help="기본 2라운드. --deep 시 최대 3(미합의 시 조건부 4~5).")
    ap.add_argument("--deep", action="store_true",
                    help="심화 모드: 최대 3라운드 + 다양성/반증 강화. 미합의·고불확실 시에만 4~5 adaptive escalation.")
    ap.add_argument("--seed", type=int, default=None)
    ap.add_argument("--with-memory", action="store_true", help="프로젝트 메모리 주입 (기본: off)")
    ap.add_argument("--no-cache", action="store_true", help="24h 캐시 무시하고 새로 토론")
    ap.add_argument("--roles", default=None,
                    help=f"명시 역할 (쉼표). critic 자동 추가. 가능: {','.join(ROLE_REGISTRY.keys())}")
    ap.add_argument("--auto-roles", action="store_true",
                    help="planner LLM이 task 보고 자동 선정 (critic 자동 추가)")
    ap.add_argument("--max-roles", type=int, default=4, help="자동선정 시 역할 상한 (기본 4)")
    ap.add_argument("--max-total-calls", type=int, default=24,
                    help="planner 포함 총 콜 예산 (기본 24). 초과 시 시작 전 중단.")
    ap.add_argument("--dry-run", action="store_true",
                    help="planner+선택역할+예상콜수만 출력, 실제 에이전트 호출 안 함")
    args = ap.parse_args()
    # --deep: 기본 최대 3라운드(다양성·반증 강화). 4~5는 adaptive escalation 으로만.
    # MAD groupthink/Degeneration-of-Thought 연구 반영 (2026-06-04 ai-debate run-20260604T085529Z).
    deep_escalate_max = args.max_rounds
    if args.deep:
        args.max_rounds = max(args.max_rounds, 3)
        deep_escalate_max = max(args.max_rounds, 5)
        # 3라운드 기본 + 조건부 5라운드까지 → 예산 상향 (5×2역할×3풀 + arbiter = 31).
        args.max_total_calls = max(args.max_total_calls, 40)

    task = args.task
    # stdin pipe 로 컨텍스트가 들어온 경우에만 합친다. 백그라운드 실행 시 stdin 이
    # tty 아니면서 EOF 도 안 오는 열린 fd 면 read() 가 영구 블록 → select 로 데이터
    # 실제 대기 중일 때만 읽는다. (2026-06-04 자동응답 런 무한 hang 사고 후 가드 추가.)
    if not sys.stdin.isatty():
        import select
        try:
            ready, _, _ = select.select([sys.stdin], [], [], 0.5)
        except (ValueError, OSError):
            ready = []
        if ready:
            stdin_data = sys.stdin.read().strip()
            if stdin_data:
                task = stdin_data + "\n\n---\n\n" + task

    # 24h 캐시 검사 (--no-cache 또는 --seed 명시 시 우회)
    if args.no_cache:
        print("[ai-debate] --no-cache: 캐시 lookup/write 모두 skip", file=sys.stderr)
    if not args.no_cache and args.seed is None:
        import hashlib
        cache_key_src = json.dumps({
            "task": task,
            "max_rounds": args.max_rounds,
            "with_memory": args.with_memory,
        }, ensure_ascii=False, sort_keys=True)
        # 16→32 hex (128bit) 로 확장. 운영자 reports of cross-topic cache hit (V25 vs COIN-LIO)
        # 후 16-char (64bit) 충돌 가능성 배제용. 2026-05-28.
        cache_key = hashlib.sha256(cache_key_src.encode("utf-8")).hexdigest()[:32]
        cache_path = CACHE_DIR / f"{cache_key}.json"
        if cache_path.is_file() and (time.time() - cache_path.stat().st_mtime) < CACHE_TTL_SEC:
            try:
                cached = json.loads(cache_path.read_text(encoding="utf-8"))
                age_min = int((time.time() - cache_path.stat().st_mtime) / 60)
                cached_task_preview = (cached.get("task_preview") or "(no-task-stored)").replace("\n", " ")[:240]
                current_task_preview = task.replace("\n", " ")[:240]
                print(f"=== ai-debate CACHE HIT (age {age_min}min, ttl {CACHE_TTL_SEC//3600}h, key {cache_key[:16]}) ===")
                print(f"original run: {cached.get('run_id','?')}")
                print(f"cached task : {cached_task_preview}")
                print(f"current task: {current_task_preview}")
                if cached.get("task_sha256") and cached["task_sha256"] != hashlib.sha256(task.encode("utf-8")).hexdigest():
                    print("[ai-debate] WARNING: task SHA mismatch — cache poisoning 의심. --no-cache 로 재토론 권장.", file=sys.stderr)
                print("--no-cache 로 강제 재토론 가능.")
                print()
                print(cached.get("summary_text", "(empty)"))
                return
            except Exception:
                pass  # cache 깨졌으면 재토론

    seed = args.seed if args.seed is not None else int(time.time())
    rng = random.Random(seed)  # reserved for future role rotation seed
    del rng

    # 기본: 프로젝트 메모리 주입 안 함 (쓸데없는 정보가 토론 품질을 떨어뜨림).
    # 명시적으로 --with-memory 줬을 때만 주입. 컨텍스트 필요하면 task에 직접 쓰거나 stdin으로 첨부.
    memory_block = project_memory() if args.with_memory else ""

    run_id = now_iso()
    run_dir = RUN_BASE / f"run-{run_id}"
    run_dir.mkdir(parents=True, exist_ok=True)
    (run_dir / "task.txt").write_text(task, encoding="utf-8")

    # 역할 선정 (planner 호출이 필요할 수 있어 run_dir 생성 후)
    selected_roles, roles_source = select_roles(task, args, run_dir)
    # 예산 가드: planner_call(0 or 1) + len(roles) * len(POOL) * rounds + arbiter(1)
    planner_calls = 1 if roles_source == "auto" else 0
    estimated_calls = planner_calls + len(selected_roles) * len(POOL) * args.max_rounds + 1
    budget_used_msg = f"{estimated_calls}/{args.max_total_calls}"

    (run_dir / "meta.json").write_text(json.dumps({
        "seed": seed, "started": run_id, "pool": POOL,
        "roles": selected_roles, "roles_source": roles_source,
        "estimated_calls": estimated_calls, "max_total_calls": args.max_total_calls,
        "max_rounds": args.max_rounds, "memory_attached": bool(memory_block),
        "parent_session_id": os.environ.get("CLAUDE_CODE_SESSION_ID", ""),
        "parent_cwd": str(Path.cwd()),
    }, ensure_ascii=False, indent=2), encoding="utf-8")

    if estimated_calls > args.max_total_calls:
        print(f"ERROR: 예상 콜 {estimated_calls} > max-total-calls {args.max_total_calls}. 중단.", file=sys.stderr)
        print(f"  roles={selected_roles} pool={POOL} rounds={args.max_rounds}", file=sys.stderr)
        sys.exit(3)

    if args.dry_run:
        print(f"=== ai-debate DRY-RUN ===")
        print(f"run_id: {run_id}")
        print(f"roles_source: {roles_source}")
        print(f"selected_roles: {selected_roles}")
        print(f"pool: {POOL}")
        print(f"max_rounds: {args.max_rounds}")
        print(f"estimated_calls: {estimated_calls} (max {args.max_total_calls})")
        print(f"run_dir: {run_dir}")
        return

    all_outputs = []
    final_consensus = False
    rounds_done = 0
    skip_agents = set()
    effective_max = args.max_rounds       # 기본 라운드 상한 (--deep 이면 3)
    escalated = False                     # adaptive 4~5라운드 확장 여부
    round_idx = 0
    while round_idx < effective_max:
        round_idx += 1
        is_final = (round_idx >= effective_max)   # 마지막 라운드 = reconciliation
        outs = run_round(round_idx, task, memory_block, all_outputs, run_dir, skip_agents,
                         roles=selected_roles, is_final_round=is_final)
        (run_dir / f"r{round_idx}.outputs.json").write_text(
            json.dumps(outs, ensure_ascii=False, indent=2), encoding="utf-8")
        all_outputs.extend(outs)
        rounds_done = round_idx
        # 이번 라운드에서 모든 role이 실패한 provider는 다음 라운드 skip 대상
        for agent in POOL:
            agent_outs = [o for o in outs if o.get("_agent") == agent]
            if agent_outs and all("_error" in o for o in agent_outs):
                skip_agents.add(agent)
        if "debater" in selected_roles and "critic" in selected_roles and consensus_reached(outs):
            final_consensus = True
            break
        # adaptive escalation (--deep 전용): 기본 라운드 다 썼는데 미합의 + 핵심충돌/저신뢰 → 4~5라운드로 1회 확장.
        if (args.deep and not escalated and round_idx >= args.max_rounds
                and effective_max < deep_escalate_max and escalation_triggered(outs)):
            effective_max = deep_escalate_max
            escalated = True
            (run_dir / "escalation.txt").write_text(
                f"escalated {args.max_rounds}->{deep_escalate_max} at round {round_idx}: 미합의 + trigger(critic 분기/저신뢰)\n",
                encoding="utf-8")

    # 부분 실패 임계: 성공 콜 / 예정 콜 < 2/3 이면 arbiter 안 부르고 실패 종료.
    expected_round_calls = len(selected_roles) * len(POOL) * rounds_done
    success_calls = sum(1 for o in all_outputs if "_error" not in o)
    if expected_round_calls > 0 and success_calls * 3 < expected_round_calls * 2:
        print(f"ERROR: 성공 콜 {success_calls}/{expected_round_calls} < 2/3. arbiter 건너뛰고 실패 종료.", file=sys.stderr)
        for hl in provider_health_lines(run_dir, all_outputs, None):
            print(hl, file=sys.stderr)
        (run_dir / "final_result.json").write_text(json.dumps({
            "run_id": run_id, "run_dir": str(run_dir),
            "rounds_done": rounds_done, "consensus_reached": False,
            "partial_failure": True, "success_calls": success_calls,
            "expected_calls": expected_round_calls,
            "outputs": all_outputs,
        }, ensure_ascii=False, indent=2), encoding="utf-8")
        sys.exit(4)

    # arbiter는 항상 최종 정리자
    arb = run_arbiter(task, memory_block, all_outputs, run_dir)
    all_outputs.append(arb)

    final = {
        "run_id": run_id,
        "run_dir": str(run_dir),
        "seed": seed,
        "rounds_done": rounds_done,
        "consensus_reached": final_consensus,
        "max_rounds": args.max_rounds,
        "outputs": all_outputs,
    }
    (run_dir / "final_result.json").write_text(
        json.dumps(final, ensure_ascii=False, indent=2), encoding="utf-8")

    # human summary (also captured for cache)
    summary_lines = []
    def _p(s=""):
        summary_lines.append(s)
        print(s)
    _p(f"=== ai-debate run {run_id} ===")
    _p(f"rounds={rounds_done}/{args.max_rounds} consensus={final_consensus}")
    _p(f"roles={selected_roles} ({roles_source}) budget={budget_used_msg}")
    # 시스템 헤더: 실제 호출된 에이전트 + 성공/실패 카운트 (arbiter narrative와 무관, 사실).
    agent_stats = {}
    for o in all_outputs:
        a = o.get("_agent")
        if not a or a == "arbiter":
            continue
        agent_stats.setdefault(a, [0, 0])
        if "_error" in o:
            agent_stats[a][1] += 1
        else:
            agent_stats[a][0] += 1
    participants = " | ".join(f"{a}={ok}ok/{fail}fail" for a, (ok, fail) in sorted(agent_stats.items())) or "-"
    _p(f"agents: {participants}")
    _p(f"artifacts={run_dir}")
    for hl in provider_health_lines(run_dir, all_outputs, arb):
        _p(hl)
    _p()

    # 라운드별 요약. 무옵션(legacy)이면 기존 per-agent 라벨 유지, 동적이면 역할별 집계.
    is_legacy = roles_source == "default"
    for r in range(1, rounds_done + 1):
        if is_legacy:
            deb_pos = []
            crit_sp = []
            for o in all_outputs:
                if o.get("_round") != r or "_error" in o:
                    continue
                if o.get("_role") == "debater":
                    p = (o.get("position", "") or "").strip()[:60]
                    deb_pos.append(f"{o.get('_agent')}={p}")
                elif o.get("_role") == "critic":
                    sp = o.get("should_proceed")
                    crit_sp.append(f"{o.get('_agent')}={'OK' if sp in (True, 'true', 'yes', 'Y', 'y', 'True', '예', 1) else 'NO'}")
            errs = [f"{o.get('_agent')}/{o.get('_role')}:{o['_error']}" for o in all_outputs if o.get("_round") == r and "_error" in o]
            _p(f"R{r}  debaters: {' | '.join(deb_pos) or '-'}")
            _p(f"     critics : {' | '.join(crit_sp) or '-'}")
            if errs:
                _p(f"     errors  : {' ; '.join(errs)}")
        else:
            # 역할별 성공/실패 카운트만 (per-agent 라벨 제거)
            _p(f"R{r}")
            for role in selected_roles:
                role_outs = [o for o in all_outputs if o.get("_round") == r and o.get("_role") == role]
                ok = sum(1 for o in role_outs if "_error" not in o)
                fail = len(role_outs) - ok
                _p(f"   {role:14s} ok={ok} fail={fail}")
        _p()

    # arbiter 최종 결정
    if "_error" in arb:
        _p(f"ARBITER FAILED: {arb['_error']}")
        for hl in provider_health_lines(run_dir, all_outputs, arb):
            _p(hl)
        return
    _p("--- ARBITER (codex) ---")
    fd = arb.get("final_decision", "(no decision)")
    _p(f"FINAL: {fd}")
    rationale = arb.get("rationale", "")
    if rationale:
        _p(f"  rationale: {rationale}")
    steps = arb.get("action_steps")
    if steps:
        if isinstance(steps, list):
            _p("  action_steps:")
            for s in steps:
                _p(f"    - {s}")
        else:
            _p(f"  action_steps: {steps}")
    vp = arb.get("verification_plan")
    if vp:
        _p(f"  verification_plan: {vp}")
    dt = arb.get("delegation_target")
    if dt:
        _p(f"  delegation_target: {dt}")
    sc = arb.get("stop_condition")
    if sc:
        _p(f"  stop_condition: {sc}")
    # 신규 다역할 필드 (있으면 출력)
    for k in ("risks", "open_questions", "role_coverage", "call_budget_used", "minority_survived"):
        v = arb.get(k)
        if v:
            if isinstance(v, list):
                _p(f"  {k}:")
                for s in v:
                    _p(f"    - {s}")
            else:
                _p(f"  {k}: {v}")
    dissent = arb.get("dissent")
    if dissent:
        _p(f"  dissent: {dissent}")

    # cache 기록 (--no-cache 또는 --seed 명시 시 skip)
    if not args.no_cache and args.seed is None:
        try:
            import hashlib as _h
            CACHE_DIR.mkdir(parents=True, exist_ok=True)
            cache_path.write_text(json.dumps({
                "run_id": run_id,
                "summary_text": "\n".join(summary_lines),
                # 진단용: task 원문 hash 와 preview 보존 (cross-topic cache hit 디버깅).
                "task_sha256": _h.sha256(task.encode("utf-8")).hexdigest(),
                "task_preview": task[:480],
                # 2026-06-04 anti-conformity: round1 독립출력 + dissent 보존 →
                # 잘못 수렴된 최종 요약만 재사용되는 것을 사람이 검증 가능하게.
                "round1_outputs": [
                    {"agent": o.get("_agent"), "role": o.get("_role"),
                     "position": o.get("position"), "should_proceed": o.get("should_proceed")}
                    for o in all_outputs if o.get("_round") == 1 and "_error" not in o
                ],
                "arbiter_dissent": arb.get("dissent"),
                "minority_survived": arb.get("minority_survived"),
                "escalated": escalated,
            }, ensure_ascii=False), encoding="utf-8")
        except Exception:
            pass


if __name__ == "__main__":
    main()
