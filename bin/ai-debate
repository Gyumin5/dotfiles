SCHEMAS = {role: cfg["schema"] for role, cfg in ROLE_REGISTRY.items()}
SCHEMAS["arbiter"] = [
    "final_decision",
    "rationale",
    "action_steps",
    "verification_plan",
    "delegation_target",
    "stop_condition",
    "dissent",
    # 신규 (동적 다역할용, 선택적). 무옵션 호환 위해 파싱은 둘 다 허용.
    "risks",
