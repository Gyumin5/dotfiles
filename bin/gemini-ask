#!/bin/bash
# gemini-ask: Antigravity CLI (agy) wrapper — 라벨은 gemini 유지, 백엔드는 agy.
#
# 2026-05-21 마이그레이션: gemini-cli (EOL 2026-06-18) → antigravity CLI.
# 외부 호출자 4개 (ai-morning-briefing, ai-briefing-review, ai-weekly-review,
# kill-ai-zombies) 의 API 호환을 위해 wrapper 보존.
#
# Usage:
#   gemini-ask "프롬프트"                       - 새 호출 (이전엔 latest resume)
#   gemini-ask --new "프롬프트"                 - 새 호출 (default 와 동일)
#   gemini-ask --session <id> "프롬프트"        - agy --conversation <id>
#   gemini-ask --topic "주제" "프롬프트"        - 토픽 매칭 미지원 → 새 호출
#   gemini-ask --list                           - agy 미지원 → 빈 출력
#   echo "..." | gemini-ask "..."               - stdin pipe 지원

set -uo pipefail

AGY=/home/gmoh/.local/bin/agy

_AI_TELEM_START=$(date +%s%3N)
_AI_TELEM_KIND=""
_ai_telem_finalize() {
    local ec=$?
    local dur=$(( $(date +%s%3N) - _AI_TELEM_START ))
    local mode="new"
    [ -n "$SESSION_ID" ] && mode="session"
    case $ec in
        2) _AI_TELEM_KIND="rate_limit_429" ;;
        3) _AI_TELEM_KIND="auth_401" ;;
        4) _AI_TELEM_KIND="server_500" ;;
        1) [ -z "$_AI_TELEM_KIND" ] && _AI_TELEM_KIND="empty_response" ;;
    esac
    ai-telemetry-log gemini "$ec" "$dur" "$mode" "$_AI_TELEM_KIND" 2>/dev/null || true
}
trap _ai_telem_finalize EXIT

FORCE_NEW=false
TOPIC=""
SESSION_ID=""

while [[ "${1:-}" == --* ]]; do
    case "$1" in
        --new)
            FORCE_NEW=true
            shift
            ;;
        --topic)
            TOPIC="$2"
            shift 2
            ;;
        --session)
            SESSION_ID="$2"
            shift 2
            ;;
        --list)
            # agy has no session list. Print informational note + exit clean.
            echo "[gemini-ask] --list: agy 미지원. (gemini-cli EOL 후 세션 기능 비활성)" >&2
            exit 0
            ;;
        *)
            echo "Unknown flag: $1" >&2
            shift
            ;;
    esac
done

PROMPT="${1:-}"
if [ -z "$PROMPT" ]; then
    echo "Usage: gemini-ask [--new|--topic TOPIC|--session ID] \"프롬프트\"" >&2
    exit 1
fi

# agy resume flag
RESUME_ARG=()
if [ -n "$SESSION_ID" ]; then
    RESUME_ARG=(--conversation "$SESSION_ID")
fi

run_gemini() {
    local output exit_code
    if [ -t 0 ]; then
        output=$(timeout --kill-after=10s 600 "$AGY" "${RESUME_ARG[@]}" -p "$PROMPT" --print-timeout 5m 2>&1)
    else
        output=$(cat | timeout --kill-after=10s 600 "$AGY" "${RESUME_ARG[@]}" -p "$PROMPT" --print-timeout 5m 2>&1)
    fi
    exit_code=$?

    if echo "$output" | grep -qE 'MODEL_CAPACITY_EXHAUSTED|429|RESOURCE_EXHAUSTED'; then
        echo "[gemini-ask] 서버 용량 부족 (429)." >&2
        echo "$output"
        return 2
    elif echo "$output" | grep -qE '401|UNAUTHENTICATED|invalid_grant'; then
        echo "[gemini-ask] 인증 만료 (401). agy 재로그인 필요." >&2
        echo "$output"
        return 3
    elif echo "$output" | grep -qE '500|INTERNAL'; then
        echo "[gemini-ask] 서버 내부 오류 (500)." >&2
        echo "$output"
        return 4
    elif [ $exit_code -ne 0 ] && [ -z "$output" ]; then
        echo "[gemini-ask] 빈 응답 (exit code: $exit_code)" >&2
        return 1
    fi

    echo "$output"
    return $exit_code
}

if [ "${AI_OUT_RAW:-}" = "1" ]; then
    run_gemini
else
    run_gemini | ai-out-filter gemini
fi
