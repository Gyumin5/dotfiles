#!/bin/bash
# claude-progress-updater: 세션 transcript jsonl을 분석해 progress.md/history.md 자동 갱신.
# 메인 세션 블로킹 없이 헤드리스 claude -p로 차분 요약 생성.
#
# 사용:
#   claude-progress-updater <project-cwd>
#   예: claude-progress-updater /home/gmoh/test_claude
#
# 동작:
#   1. cwd → claude project key (/와 _ 를 -로) → transcript jsonl 위치 결정
#   2. 가장 최신 jsonl의 last-processed offset (state file) 이후 entries 추출
#   3. 기존 progress.md/history.md + 새 entries → claude -p로 갱신본 생성
#   4. atomic replace progress.md + append history.md
#   5. offset 갱신

set -uo pipefail

CWD="${1:?usage: claude-progress-updater <project-cwd>}"
[ -d "$CWD" ] || { echo "[updater] cwd $CWD not found" >&2; exit 1; }

export NVM_DIR="$HOME/.nvm"
set +u; [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"; set -u
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

LOG_DIR="$HOME/.claude/logs"
STATE_DIR="$HOME/.claude/state/progress-updater"
mkdir -p "$LOG_DIR" "$STATE_DIR"

PROJ_KEY=$(echo "$CWD" | sed -e 's|/|-|g' -e 's|_|-|g')
PROJ_DIR="$HOME/.claude/projects/${PROJ_KEY}"
[ -d "$PROJ_DIR" ] || { echo "[updater] proj dir $PROJ_DIR not found" >&2; exit 1; }

LATEST_JSONL=$(ls -t "$PROJ_DIR"/*.jsonl 2>/dev/null | head -1)
[ -z "$LATEST_JSONL" ] && { echo "[updater] no jsonl in $PROJ_DIR" >&2; exit 0; }

STATE_FILE="$STATE_DIR/$(basename "$CWD").state"
LOG_FILE="$LOG_DIR/progress-updater.log"

log() { echo "[$(date -Iseconds)] [$(basename "$CWD")] $1" >> "$LOG_FILE"; }

# 마지막 처리 offset 읽기 (jsonl line count)
last_offset=0
[ -f "$STATE_FILE" ] && last_offset=$(cat "$STATE_FILE" 2>/dev/null || echo 0)

cur_lines=$(wc -l < "$LATEST_JSONL" 2>/dev/null || echo 0)
new_lines=$(( cur_lines - last_offset ))

# 2026-05-21: offset 추적 버그 픽스 + bounded mode.
# 1. 파일이 rotate/truncate 되어 cur_lines < last_offset 이면 offset reset (deadlock 회피).
# 2. 새 entries 가 너무 많으면 (MAX_NEW_LINES) tail 만 처리. 큰 jsonl 에서 OOM/timeout 회피.
MAX_NEW_LINES=500
if [ "$cur_lines" -lt "$last_offset" ]; then
    log "rotation detected (offset=$last_offset, cur=$cur_lines) → offset reset"
    last_offset=$(( cur_lines > MAX_NEW_LINES ? cur_lines - MAX_NEW_LINES : 0 ))
    new_lines=$(( cur_lines - last_offset ))
fi

if [ "$new_lines" -le 0 ]; then
    log "no new entries (offset=$last_offset, cur=$cur_lines)"
    exit 0
fi

if [ "$new_lines" -gt "$MAX_NEW_LINES" ]; then
    log "new_lines=$new_lines truncated to tail $MAX_NEW_LINES (bounded mode)"
    new_lines="$MAX_NEW_LINES"
fi

# 새 entries 추출 (text turns만, 너무 길면 자르기)
DIFF_FILE=$(mktemp)
trap 'rm -f "$DIFF_FILE"' EXIT
tail -n "$new_lines" "$LATEST_JSONL" | python3 -c "
import json, sys
for line in sys.stdin:
    try:
        d = json.loads(line)
    except:
        continue
    t = d.get('type', '')
    ts = (d.get('timestamp', '') or '')[:19]
    msg = d.get('message', {}) or {}
    if t == 'user':
        c = msg.get('content', '')
        if isinstance(c, str) and c.strip() and not c.startswith('<system-reminder>'):
            print(f'U[{ts}] {c[:500]}')
    elif t == 'assistant':
        c = msg.get('content', [])
        if isinstance(c, list):
            for it in c:
                if isinstance(it, dict):
                    if it.get('type') == 'text':
                        x = (it.get('text') or '').strip()
                        if x:
                            print(f'A[{ts}] {x[:500]}')
                    elif it.get('type') == 'tool_use':
                        print(f'A[{ts}] [tool:{it.get(\"name\",\"?\")}]')
" > "$DIFF_FILE"

diff_size=$(wc -c < "$DIFF_FILE")
# 2026-05-21: skip 룰 완화 (1500 → 300). 도구 위주 세션도 갱신 빈도 증가.
if [ "$diff_size" -lt 300 ]; then
    log "diff too small ($diff_size bytes), skip"
    echo "$cur_lines" > "$STATE_FILE"
    exit 0
fi

# diff 상한 강화: 30KB → 12KB (claude -p input 토큰 절약)
if [ "$diff_size" -gt 12000 ]; then
    head -c 12000 "$DIFF_FILE" > "${DIFF_FILE}.trim"
    mv "${DIFF_FILE}.trim" "$DIFF_FILE"
    log "diff trimmed to 12KB"
fi

PROG="$CWD/progress.md"
HIST="$CWD/history.md"

# 기존 progress.md (없으면 빈 템플릿)
existing_prog=""
[ -f "$PROG" ] && existing_prog=$(head -c 8000 "$PROG")

# 2026-05-21: PostToolUse delta jsonl 도 프롬프트에 포함 (도구 위주 세션 활동 흔적).
# 마지막 100줄만, 합쳐 5KB 이내로 자름.
DELTA_FILE="$HOME/.claude/state/progress-delta/$(basename "$CWD").jsonl"
delta_summary=""
if [ -f "$DELTA_FILE" ]; then
    delta_summary=$(tail -n 100 "$DELTA_FILE" 2>/dev/null \
        | jq -r '"[" + (.ts // "?")[11:19] + "] " + .kind + " " + (.hint // "")' 2>/dev/null \
        | tail -c 5000)
fi

# claude -p로 progress.md 갱신본 + history.md 새 entry 생성
PROMPT=$(cat <<EOF
다음은 진행 중인 작업의 transcript 요약과 기존 progress.md다. 새 entries를 반영해서 progress.md를 갱신해라.

## 기존 progress.md
$existing_prog

## 새 transcript (마지막 처리 후 추가분)
$(cat "$DIFF_FILE")

## 최근 도구 활동 (PostToolUse delta — text turn 없이 실행된 명령/편집 흔적)
$delta_summary

## 작업
1. 기존 progress.md 위에 새 entries에서 의미있는 결정/방향 변경/작업 완료/블로커만 반영해서 갱신본 작성
2. 잡담, 단순 Q&A, 중간 디버깅 무시
3. 형식 유지: # 진행 상황 (YYYY-MM-DD), ## 완성된 시스템 개요, ## 현재 상태, ## 다음 작업 등
4. 출력은 갱신된 progress.md 전문 ONLY. 마크다운 코드펜스(\`\`\`) 금지. 서론/메타 멘트 금지.
5. 길이 제한: 80줄 이하. 새 내용 추가 시 오래된 정보 삭제·압축. 토큰 절약 우선.

CRITICAL 출력 규약 (위반 시 자동 거부됨):
- 첫 문자는 반드시 '#' (markdown 헤더). 예: '# progress.md' 또는 '# 진행 상황 (YYYY-MM-DD)'.
- 한 줄 요약 sentence ("갱신 완료", "변경 사항 반영" 등) 금지. 반드시 전문 markdown 문서.
- 기존 progress.md 길이의 30% 이상은 유지 (기존 ${#existing_prog} bytes → 최소 $((${#existing_prog} * 30 / 100)) bytes).
- 다른 프로젝트 (helipr/bias/intensitylio/velocity 등) 내용 포함 금지. 현재 cwd = $CWD 의 작업만.
EOF
)

log "calling claude -p (diff=$diff_size bytes, prog=${#existing_prog} bytes)"
# CLAUDE_AUTOMATED=1: 자동 hook들이 사용자 세션이 아님을 인지해서 스킵하도록.
# - telegram-reply-injector / enforcer: prompt 안에 채널 태그 있어도 reply 강제 X (이전 leak 원인).
# - rate-limit-prompt-guard: 자동 작업이므로 큐잉 대상 아님.
NEW_PROG=$(CLAUDE_AUTOMATED=1 timeout 90 claude -p "$PROMPT" 2>> "$LOG_FILE")

if [ -z "$NEW_PROG" ] || [ "${#NEW_PROG}" -lt 300 ]; then
    log "claude returned empty/short response (<300 chars), skip"
    exit 0
fi

# size-ratio guard: 새 출력이 기존 progress.md 의 30% 미만이면 거부.
# 요약 sentence ("progress.md 갱신 완료. ...") 같은 무용한 응답 차단.
if [ "${#existing_prog}" -gt 500 ]; then
    min_required=$(( ${#existing_prog} * 30 / 100 ))
    if [ "${#NEW_PROG}" -lt "$min_required" ]; then
        log "NEW_PROG too small (${#NEW_PROG} < ${min_required}=existing*0.3), skip — likely summary sentence"
        exit 0
    fi
fi

# 출력은 반드시 '# ' (markdown 헤더) 로 시작해야 progress.md 전문으로 인정.
NEW_PROG_HEAD=$(printf '%s' "$NEW_PROG" | head -c 200 | tr -d '\r')
case "$NEW_PROG_HEAD" in
    \#*) ;;
    *)
        log "NEW_PROG does not start with '#' header, skip — likely meta sentence"
        exit 0
        ;;
esac

# 출력 길이 상한 (8KB / ~120줄). 초과하면 80줄로 잘라 토큰·디스크 절약.
if [ "${#NEW_PROG}" -gt 8000 ]; then
    NEW_PROG=$(printf '%s\n' "$NEW_PROG" | head -n 80)
    log "NEW_PROG trimmed to 80 lines (was ${#NEW_PROG}+ bytes)"
fi

# 안전장치: 토픽 드리프트 감지 (cross-session leak 방지).
# NEW_PROG 의 첫 800자 vs existing_prog 의 첫 800자 단어 집합 비교 (3자 이상 토큰).
# Jaccard similarity < 0.15 면 헤드리스 claude 가 다른 세션 내용을 썼다고 보고
# 기존 progress.md 보존 + proposed-progress.md 로만 기록.
DRIFT=$(EXISTING_PROG="$existing_prog" NEW_PROG_TXT="$NEW_PROG" python3 - <<'PYEOF'
import os, re
# 보일러플레이트 (progress.md 공통 헤더 단어) 제외
STOP = {
    "progress", "task", "updated", "status", "goal", "current", "state",
    "decisions", "force", "resume", "hints", "blockers", "active", "paused",
    "abandoned", "handoff", "kst", "utc", "do", "not", "repeat", "the", "and",
    "for", "with", "this", "that", "from", "into", "after", "before", "section",
}
a = (os.environ.get("EXISTING_PROG", "") or "")[:1500].lower()
b = (os.environ.get("NEW_PROG_TXT", "") or "")[:1500].lower()
def toks(s):
    raw = re.findall(r"[a-z0-9_가-힣]+", s)
    out = set()
    for w in raw:
        if len(w) < 3:
            continue
        if w in STOP:
            continue
        if re.fullmatch(r"\d{4}", w) or re.fullmatch(r"\d{2}", w):
            continue  # 연·월 숫자
        out.add(w)
    return out
A, B = toks(a), toks(b)
if len(A) < 3 or len(B) < 3:
    print("nodata")
else:
    inter = len(A & B); uni = len(A | B)
    sim = inter / uni if uni else 0
    print(f"{sim:.2f}")
PYEOF
)
case "$DRIFT" in
    nodata) ;;
    *)
        # bash 부동소수 비교: awk
        IS_DRIFT=$(awk -v s="$DRIFT" 'BEGIN{print (s+0 < 0.15) ? 1 : 0}')
        if [ "$IS_DRIFT" = "1" ]; then
            log "TOPIC DRIFT detected (similarity=$DRIFT). 기존 progress.md 보존, proposed-progress.md로 기록."
            PROPOSED="$CWD/proposed-progress.md"
            {
                echo "<!-- auto-generated by claude-progress-updater at $(date -Iseconds) -->"
                echo "<!-- TOPIC DRIFT detected (jaccard=$DRIFT). Headless claude session may have leaked another project. -->"
                echo "<!-- existing progress.md preserved; review this proposal manually before merge. -->"
                echo ""
                echo "$NEW_PROG"
            } > "$PROPOSED.tmp" && mv "$PROPOSED.tmp" "$PROPOSED"
            echo "$cur_lines" > "$STATE_FILE"
            # 2026-05-21: drift 텔레그램 alert 비활성화. proposed-progress.md 로 조용히 기록.
            # 본 progress.md 는 안전하게 보존되며, 사용자가 필요할 때 proposed-progress.md 직접 확인 가능.
            # 노이즈 발생 사고: 2026-05-21 12:44 intensitylio + 12:45 test_claude 연속 alert.
            exit 0
        fi
        ;;
esac

# dry-run 기본: proposed-progress.md 생성. 사용자/Claude가 검토 후 머지.
# UPDATER_AUTO_MERGE=1 환경변수 설정 시 직접 progress.md 덮어씀 (예전 동작).
PROPOSED="$CWD/proposed-progress.md"
if [ "${UPDATER_AUTO_MERGE:-0}" = "1" ]; then
    # 백업: 기존 progress.md를 ~/.claude/state/progress-updater/backups/<proj>/<ts>.md 로 보존 (감사용)
    BACKUP_DIR="$HOME/.claude/state/progress-updater/backups/$(basename "$CWD")"
    mkdir -p "$BACKUP_DIR"
    if [ -f "$PROG" ]; then
        cp "$PROG" "$BACKUP_DIR/$(date +%Y%m%d-%H%M%S).md" 2>/dev/null || true
        # 30일 이상 된 백업 정리
        find "$BACKUP_DIR" -name '*.md' -mtime +30 -delete 2>/dev/null || true
    fi
    echo "$NEW_PROG" > "$PROG.tmp" && mv "$PROG.tmp" "$PROG"
    log "progress.md updated directly (UPDATER_AUTO_MERGE=1, ${#NEW_PROG} bytes, backup ok)"
else
    {
        echo "<!-- auto-generated by claude-progress-updater at $(date -Iseconds) -->"
        echo "<!-- source: transcript diff (offset $last_offset → $cur_lines, $diff_size bytes) -->"
        echo "<!-- review and merge into progress.md if intent matches; delete this file otherwise -->"
        echo ""
        echo "$NEW_PROG"
    } > "$PROPOSED.tmp" && mv "$PROPOSED.tmp" "$PROPOSED"
    log "proposed-progress.md written (${#NEW_PROG} bytes, dry-run)"
fi

# offset 갱신
echo "$cur_lines" > "$STATE_FILE"

exit 0
