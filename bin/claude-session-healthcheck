#!/usr/bin/env python3
"""claude-session-healthcheck — 활성 세션 30분 무응답 감지 + 알림.

매 15분 timer가 호출. 각 systemd claude-*.service 활성 세션에 대해:
- /proc/<pid>/cwd 에서 cwd 얻고 ~/.claude/projects/<key>/ 의 최근 .jsonl 파일 찾기
- 마지막 user/assistant ts, 마지막 tool_use 후 매칭되는 tool_result 없으면 in-flight
- 30분 이상 응답 없고 in-flight tool 도 없으면 컨트롤봇으로 알림 (PaperVelocity 누출 후
  알림 정책: 컨트롤봇 한 채팅으로만)
- 세션별 60분 쿨다운

알림 내용:
- 세션명, 마지막 활동(분), stop hook 발화 여부, jsonl 마지막 event type, systemd 상태
"""
import json
import os
import re
import subprocess
import sys
import time
from pathlib import Path

THRESHOLD_NO_ACTIVITY_SEC = 30 * 60
ALERT_COOLDOWN_SEC = 60 * 60
TOOL_INFLIGHT_WINDOW_SEC = 5 * 60
# stuck-loop 예외: in-flight tool 이 있어도 assistant 응답이 너무 오래 끊기고
# 큐잉된 사용자 prompt 가 누적되면 stuck 으로 판정 (2026-05-11 intensitylio 사고).
STUCK_NO_ASSISTANT_SEC = 60 * 60
STUCK_QUEUE_OP_MIN = 3
# 자동 복구 (2026-05-28 intensitylio 1h thinking hang 사고 후):
# assistant 무응답 60분 + in-flight tool 없음 + 큐잉 사용자 ≥ 1 + rate-limit 차단 아님
# + 직전 healthcheck 동일 상태 → 자동 cs restart.
AUTO_RESTART_ASSISTANT_AGE_SEC = 60 * 60
AUTO_RESTART_QUEUED_USER_MIN = 1
# 동일 세션 자동 restart 제한.
AUTO_RESTART_6H_MAX = 1
AUTO_RESTART_24H_MAX = 2
# 글로벌 동시 restart 제한 (한 tick 에 1세션만).
AUTO_RESTART_GLOBAL_MAX_PER_TICK = 1
# shadow mode: 실제 cs restart 안 부르고 would-restart 로그만 기록.
# 7일 운영 검토 후 사용자 승인 시 ~/.claude/state/auto-restart-enforce.flag 생성하여 enforce.
SHADOW_FLAG = Path.home() / ".claude" / "state" / "auto-restart-enforce.flag"
AUTO_RESTART_STATE_DIR = Path.home() / ".claude" / "state" / "auto-restart"
STATUSLINE_CACHE = Path.home() / ".claude" / "statusline_cache.json"
RATE_LIMIT_5H_BLOCK_PCT = 90
RATE_LIMIT_7D_BLOCK_PCT = 99
EXCLUDE_SERVICES = {
    "claude-watchdog.service",
    "claude-control-bot.service",
    "claude-progress-updater.service",
    "claude-rate-limit-recovery.service",
    "claude-session-healthcheck.service",
    "claude-daily-research.service",
}
STATE_DIR = Path.home() / ".claude" / "state"
STATE_DIR.mkdir(parents=True, exist_ok=True)
CONTROL_BOT_ENV = Path.home() / ".claude" / "control-bot" / ".env"
CONTROL_CHAT_ID = "8689118207"


def load_control_token():
    if not CONTROL_BOT_ENV.is_file():
        return None
    try:
        for line in CONTROL_BOT_ENV.read_text().splitlines():
            if "=" in line and not line.strip().startswith("#"):
                k, v = line.split("=", 1)
                if k.strip() == "CONTROL_BOT_TOKEN":
                    return v.strip().strip('"').strip("'")
    except Exception:
        return None
    return None


def telegram_alert(token, text):
    if not token:
        return False
    try:
        import urllib.parse
        import urllib.request

        url = f"https://api.telegram.org/bot{token}/sendMessage"
        data = urllib.parse.urlencode(
            {"chat_id": CONTROL_CHAT_ID, "text": text}
        ).encode()
        req = urllib.request.Request(url, data=data, method="POST")
        urllib.request.urlopen(req, timeout=5).read()
        return True
    except Exception:
        return False


def list_active_services():
    try:
        out = subprocess.run(
            [
                "systemctl",
                "--user",
                "list-units",
                "--type=service",
                "--state=active",
                "--no-legend",
                "--plain",
                "claude-*.service",
            ],
            capture_output=True,
            text=True,
            timeout=10,
        ).stdout
    except Exception:
        return []
    services = []
    for line in out.splitlines():
        parts = line.split()
        if not parts:
            continue
        svc = parts[0]
        if svc in EXCLUDE_SERVICES:
            continue
        services.append(svc)
    return services


def service_main_pid(svc):
    try:
        out = subprocess.run(
            ["systemctl", "--user", "show", "-p", "MainPID", "--value", svc],
            capture_output=True,
            text=True,
            timeout=5,
        ).stdout.strip()
        pid = int(out)
        return pid if pid > 0 else None
    except Exception:
        return None


def proc_cwd(pid):
    try:
        return os.readlink(f"/proc/{pid}/cwd")
    except Exception:
        return None


def project_key(cwd):
    return cwd.replace("/", "-").replace("_", "-")


def latest_jsonl(proj_dir):
    if not proj_dir.is_dir():
        return None
    candidates = [
        p
        for p in proj_dir.glob("*.jsonl")
        if p.is_file() and "archive" not in p.parts
    ]
    if not candidates:
        return None
    return max(candidates, key=lambda p: p.stat().st_mtime)


def parse_jsonl_tail(path, n=200):
    """Return last n parsed events from jsonl."""
    try:
        size = path.stat().st_size
    except Exception:
        return []
    chunk = min(size, 256 * 1024)  # 마지막 256KB
    try:
        with open(path, "rb") as f:
            f.seek(max(0, size - chunk))
            raw = f.read().decode("utf-8", errors="ignore")
    except Exception:
        return []
    lines = raw.splitlines()[-n:]
    events = []
    for ln in lines:
        ln = ln.strip()
        if not ln:
            continue
        try:
            events.append(json.loads(ln))
        except Exception:
            continue
    return events


def event_ts(ev):
    """Return unix ts from event timestamp string, or None."""
    ts = ev.get("timestamp")
    if not ts:
        return None
    try:
        if ts.endswith("Z"):
            from datetime import datetime, timezone

            return datetime.fromisoformat(ts.replace("Z", "+00:00")).timestamp()
        from datetime import datetime

        return datetime.fromisoformat(ts).timestamp()
    except Exception:
        return None


def analyze_session(events):
    """From parsed events, return dict with last_user_ts, last_assistant_ts,
    inflight_tool_use (bool), last_event_type."""
    last_user = None
    last_assistant = None
    last_event_type = None
    pending_tool_use_ts = None
    matched_tool_use_ids = set()
    pending_tool_use_ids = []  # list of (id, ts)
    pending_user_msgs = []  # 텔레그램 사용자 메시지 큐잉만 모음 (ts list)

    for ev in events:
        t = ev.get("type")
        last_event_type = t or last_event_type
        ts = event_ts(ev)
        if t == "queue-operation":
            # 자율루프 재발화/task-notification 등 시스템 큐잉은 stuck 시그널 아님.
            # 진짜 사용자 메시지(<channel source=...> 태그 포함)만 추출.
            content = ev.get("content") or ""
            if isinstance(content, str) and "<channel source=" in content and ts:
                pending_user_msgs.append(ts)
            continue
        if t == "user":
            msg = ev.get("message", {}) or {}
            content = msg.get("content")
            # 진짜 user는 tool_result 가 아닌 것
            is_real_user = False
            if isinstance(content, str):
                is_real_user = True
            elif isinstance(content, list):
                for it in content:
                    if isinstance(it, dict):
                        if it.get("type") == "tool_result" or "tool_use_id" in it:
                            tid = it.get("tool_use_id")
                            if tid:
                                matched_tool_use_ids.add(tid)
                            continue
                        is_real_user = True
                        break
            if is_real_user and ts:
                last_user = ts
        elif t == "assistant":
            if ts:
                last_assistant = ts
            msg = ev.get("message", {}) or {}
            content = msg.get("content") or []
            if isinstance(content, list):
                for it in content:
                    if isinstance(it, dict) and it.get("type") == "tool_use":
                        tid = it.get("id")
                        if tid:
                            pending_tool_use_ids.append((tid, ts))

    # in-flight: pending tool_use 가 매칭 안 됨 + 5분 이내
    now = time.time()
    inflight = False
    for tid, tts in pending_tool_use_ids:
        if tid in matched_tool_use_ids:
            continue
        if tts and (now - tts) < TOOL_INFLIGHT_WINDOW_SEC:
            inflight = True
            break

    return {
        "last_user_ts": last_user,
        "last_assistant_ts": last_assistant,
        "last_event_type": last_event_type,
        "inflight": inflight,
        "pending_user_msgs": pending_user_msgs,
    }


def cooldown_ok(svc):
    flag = STATE_DIR / f"healthcheck-alert-{svc}.flag"
    if flag.exists():
        if (time.time() - flag.stat().st_mtime) < ALERT_COOLDOWN_SEC:
            return False
    return True


def mark_alert(svc):
    flag = STATE_DIR / f"healthcheck-alert-{svc}.flag"
    flag.touch()


def rate_limited():
    """statusline_cache 기준으로 현재 rate-limit 차단 임계 초과인지."""
    try:
        d = json.loads(STATUSLINE_CACHE.read_text())
        rl = d.get("rate_limits", {}) or {}
        now_ts = time.time()

        def pct(window):
            rt = window.get("resets_at")
            if rt and now_ts > rt:
                return 0
            v = window.get("used_percentage")
            return int(v) if isinstance(v, (int, float)) else 0

        if pct(rl.get("five_hour", {})) >= RATE_LIMIT_5H_BLOCK_PCT:
            return True
        if pct(rl.get("seven_day", {})) >= RATE_LIMIT_7D_BLOCK_PCT:
            return True
    except Exception:
        pass
    return False


def restart_history(svc):
    """반환: (count_6h, count_24h, last_ts)."""
    AUTO_RESTART_STATE_DIR.mkdir(parents=True, exist_ok=True)
    f = AUTO_RESTART_STATE_DIR / f"{svc}.history"
    if not f.is_file():
        return 0, 0, 0
    now = time.time()
    c6 = c24 = 0
    last = 0
    try:
        for line in f.read_text().splitlines():
            try:
                ts = int(line.strip())
            except Exception:
                continue
            if now - ts <= 6 * 3600:
                c6 += 1
            if now - ts <= 24 * 3600:
                c24 += 1
            if ts > last:
                last = ts
    except Exception:
        pass
    return c6, c24, last


def record_restart(svc):
    f = AUTO_RESTART_STATE_DIR / f"{svc}.history"
    try:
        with f.open("a") as fp:
            fp.write(f"{int(time.time())}\n")
    except Exception:
        pass


def hang_signature(svc, last_assistant_ts, pending_after):
    """hang 상태 지문 — 직전 tick 과 동일해야 자동 restart 후보 (오탐 가드)."""
    return f"{svc}|{int(last_assistant_ts or 0)}|{pending_after}"


def previous_hang_signature(svc):
    f = AUTO_RESTART_STATE_DIR / f"{svc}.last-sig"
    if not f.is_file():
        return None
    if time.time() - f.stat().st_mtime > 60 * 60:
        return None
    try:
        return f.read_text().strip()
    except Exception:
        return None


def save_hang_signature(svc, sig):
    AUTO_RESTART_STATE_DIR.mkdir(parents=True, exist_ok=True)
    f = AUTO_RESTART_STATE_DIR / f"{svc}.last-sig"
    try:
        f.write_text(sig)
    except Exception:
        pass


def clear_hang_signature(svc):
    f = AUTO_RESTART_STATE_DIR / f"{svc}.last-sig"
    try:
        f.unlink()
    except Exception:
        pass


def jsonl_unchanged_recheck(jl_path, last_assistant_ts):
    """restart 직전 jsonl tail 재확인 — 새 assistant/user 이벤트 있으면 취소.

    반환 True: 안전 (변동 없음), False: 새 이벤트 발견 → restart 취소.
    """
    try:
        events = parse_jsonl_tail(jl_path, n=100)
        info = analyze_session(events)
        new_assistant = info["last_assistant_ts"] or 0
        # 같거나 더 옛 ts 면 변동 없음.
        if new_assistant > (last_assistant_ts or 0):
            return False
        # inflight 가 새로 생겼으면 변동 있음.
        if info["inflight"]:
            return False
    except Exception:
        # 읽기 실패 시 보수적으로 False (취소).
        return False
    return True


def snapshot_auto_restart(svc, payload):
    AUTO_RESTART_STATE_DIR.mkdir(parents=True, exist_ok=True)
    ts = time.strftime("%Y%m%dT%H%M%SZ", time.gmtime())
    name = svc.replace("claude-", "").replace(".service", "")
    f = AUTO_RESTART_STATE_DIR / f"{name}-{ts}.json"
    try:
        f.write_text(json.dumps(payload, ensure_ascii=False, indent=2))
    except Exception:
        pass
    return f


def cs_restart(name):
    try:
        r = subprocess.run(
            ["/home/gmoh/dotfiles/bin/cs", "restart", name],
            capture_output=True, text=True, timeout=60,
        )
        return r.returncode == 0, (r.stdout + r.stderr)[-400:]
    except Exception as e:
        return False, str(e)


def main():
    token = load_control_token()
    services = list_active_services()
    if not services:
        return

    findings = []
    for svc in services:
        pid = service_main_pid(svc)
        if not pid:
            continue
        cwd = proc_cwd(pid)
        if not cwd:
            continue
        proj_dir = Path.home() / ".claude" / "projects" / project_key(cwd)
        jl = latest_jsonl(proj_dir)
        if not jl:
            continue
        events = parse_jsonl_tail(jl, n=300)
        info = analyze_session(events)
        # idle 계산: 마지막 user/assistant ts 만 사용. jsonl mtime 은 queue-operation
        # 이벤트로 갱신될 수 있어서 false-negative (intensitylio 5/10 hang 사고).
        last_act_candidates = [info["last_user_ts"], info["last_assistant_ts"]]
        last_act_candidates = [x for x in last_act_candidates if x is not None]
        if not last_act_candidates:
            continue
        last_act = max(last_act_candidates)
        idle = time.time() - last_act
        now = time.time()

        # stuck-loop 예외: assistant 응답이 STUCK_NO_ASSISTANT_SEC 이상 끊겼고
        # last_assistant_ts 이후 큐잉된 텔레그램 사용자 메시지가 STUCK_QUEUE_OP_MIN 이상
        # 이면 in-flight 여부 무시. 자율루프 자체가 만드는 queue-operation 은 제외.
        stuck_loop = False
        assistant_age = None
        pending_after_assistant = 0
        if info["last_assistant_ts"]:
            assistant_age = now - info["last_assistant_ts"]
            pending_after_assistant = sum(
                1
                for ts in info["pending_user_msgs"]
                if ts and ts > info["last_assistant_ts"]
            )
            if (
                assistant_age >= STUCK_NO_ASSISTANT_SEC
                and pending_after_assistant >= STUCK_QUEUE_OP_MIN
            ):
                stuck_loop = True

        # 2026-05-28 자동 복구 분기 추가. 알림은 여전히 비활성 (운영자 요청).
        #
        # 자동 restart 조건 (모두 만족):
        # - assistant 마지막 응답으로부터 AUTO_RESTART_ASSISTANT_AGE_SEC 이상
        # - in-flight tool 없음
        # - 큐잉된 사용자 메시지 (last_assistant_ts 이후) ≥ AUTO_RESTART_QUEUED_USER_MIN
        # - rate-limit 차단 상태 아님
        # - 직전 tick 의 hang signature 와 동일 (2회 연속 동일 상태)
        # - 6h 내 이 세션 restart 횟수 < AUTO_RESTART_6H_MAX
        # - 24h 내 이 세션 restart 횟수 < AUTO_RESTART_24H_MAX
        # - 이번 tick 글로벌 restart 횟수 < AUTO_RESTART_GLOBAL_MAX_PER_TICK
        # - restart 직전 jsonl 재확인에서 새 event 발견되면 취소
        name = svc.replace("claude-", "").replace(".service", "")

        is_hang_candidate = (
            assistant_age is not None
            and assistant_age >= AUTO_RESTART_ASSISTANT_AGE_SEC
            and not info["inflight"]
            and pending_after_assistant >= AUTO_RESTART_QUEUED_USER_MIN
        )
        if not is_hang_candidate:
            clear_hang_signature(svc)
            continue

        if rate_limited():
            clear_hang_signature(svc)
            continue

        sig = hang_signature(svc, info["last_assistant_ts"], pending_after_assistant)
        prev_sig = previous_hang_signature(svc)
        save_hang_signature(svc, sig)
        if prev_sig != sig:
            # 첫 발견 — 다음 tick (15분 후) 확정 후 트리거.
            continue

        c6, c24, _ = restart_history(svc)
        if c6 >= AUTO_RESTART_6H_MAX or c24 >= AUTO_RESTART_24H_MAX:
            continue

        # 글로벌 동시 restart 제한.
        if len(findings) >= AUTO_RESTART_GLOBAL_MAX_PER_TICK:
            continue

        # restart 직전 jsonl 재확인 (race 방지).
        if not jsonl_unchanged_recheck(jl, info["last_assistant_ts"]):
            clear_hang_signature(svc)
            continue

        shadow = not SHADOW_FLAG.is_file()
        payload = {
            "svc": svc,
            "name": name,
            "decided_at": time.strftime("%Y-%m-%d %H:%M:%S KST", time.localtime()),
            "shadow": shadow,
            "assistant_age_sec": int(assistant_age),
            "pending_after_assistant": pending_after_assistant,
            "inflight": info["inflight"],
            "last_event_type": info["last_event_type"],
            "last_assistant_ts": info["last_assistant_ts"],
            "last_user_ts": info["last_user_ts"],
            "jsonl": str(jl),
            "cwd": cwd,
            "restart_count_6h": c6,
            "restart_count_24h": c24,
            "rate_limited": False,
        }

        if shadow:
            payload["action"] = "would-restart"
            snapshot_auto_restart(svc, payload)
            findings.append(f"{name}(shadow)")
            continue

        ok, output = cs_restart(name)
        payload["action"] = "restart"
        payload["cs_ok"] = ok
        payload["cs_output_tail"] = output
        snapshot_auto_restart(svc, payload)

        if ok:
            record_restart(svc)
            clear_hang_signature(svc)
            telegram_alert(
                token,
                f"[healthcheck:auto-restart] {name} 자동 복구. "
                f"무응답 {int(assistant_age/60)}분, 큐잉 {pending_after_assistant}건. "
                f"6h={c6+1}/{AUTO_RESTART_6H_MAX}, 24h={c24+1}/{AUTO_RESTART_24H_MAX}.",
            )
            findings.append(name)
        else:
            telegram_alert(
                token,
                f"[healthcheck:auto-restart] {name} restart 실패: {output[:200]}",
            )

    if findings:
        print(f"[healthcheck] auto-restart: {','.join(findings)}", file=sys.stderr)


if __name__ == "__main__":
    main()
