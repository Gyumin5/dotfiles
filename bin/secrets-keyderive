#!/usr/bin/env python3
# secrets-keyderive — 사용자 키워드 → scrypt 파생 패스프레이즈.
#
# 목적: backup/restore-secrets.sh 가 쓸 gpg 패스프레이즈를, 사용자가 외우는
# "키워드" 에서 재현 가능하게 파생한다. 키워드는 어디에도 저장하지 않는다(터미널
# getpass 입력만). salt(비밀 아님)는 claude-secrets private repo 에 보관 → 같은
# 키워드 + 같은 salt = 같은 패스프레이즈(머신·시점 무관 재현).
#
# 보안 메모: scrypt 는 약한 키워드를 강하게 만들지 못한다(작업계수만 부여).
# 진짜 1차 방어막은 private repo 접근권한, 키워드는 2차. 단어 여러 개 문구 권장.
#
# 사용법:
#   secrets-keyderive --salt PATH [--out PATH] [--confirm]
#     --salt PATH   salt 파일(필수). 기본 ~/claude-secrets-repo/salt
#     --out PATH    파생 패스프레이즈를 이 파일(mode 600)에 기록. 없으면 stdout
#     --confirm     키워드를 2번 입력받아 일치 확인(백업 시 오타 방지)
#
# 키워드는 argv 로 받지 않는다(셸 히스토리/ps 노출 방지). 오직 getpass.
import argparse, base64, hashlib, os, sys

DEF_SALT = os.path.expanduser("~/claude-secrets-repo/salt")
# scrypt 파라미터 (고정 — 바꾸면 기존 번들 복호화 불가)
N, R, P, DKLEN = 1 << 15, 8, 1, 32
MAXMEM = 128 * R * N * 2  # scrypt 메모리 상한 여유

def read_keyword(confirm):
    import getpass
    kw = getpass.getpass("키워드 입력(화면 표시 안 됨): ")
    if not kw:
        sys.stderr.write("빈 키워드 거부.\n"); sys.exit(2)
    if confirm:
        kw2 = getpass.getpass("키워드 재입력(확인): ")
        if kw != kw2:
            sys.stderr.write("두 입력이 다름. 중단.\n"); sys.exit(2)
    return kw.encode("utf-8")

def main():
    ap = argparse.ArgumentParser(add_help=True)
    ap.add_argument("--salt", default=DEF_SALT)
    ap.add_argument("--out", default=None)
    ap.add_argument("--confirm", action="store_true")
    a = ap.parse_args()

    if not os.path.isfile(a.salt):
        sys.stderr.write(f"salt 파일 없음: {a.salt} (claude-secrets repo clone 필요)\n")
        sys.exit(1)
    with open(a.salt, "rb") as f:
        salt = f.read().strip()
    if not salt:
        sys.stderr.write("salt 비어있음.\n"); sys.exit(1)

    kw = read_keyword(a.confirm)
    dk = hashlib.scrypt(kw, salt=salt, n=N, r=R, p=P, dklen=DKLEN, maxmem=MAXMEM)
    passphrase = base64.b64encode(dk).decode()

    if a.out:
        fd = os.open(a.out, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        with os.fdopen(fd, "w") as f:
            f.write(passphrase)
        sys.stderr.write(f"파생 완료 → {a.out}\n")
    else:
        sys.stdout.write(passphrase)

if __name__ == "__main__":
    main()
