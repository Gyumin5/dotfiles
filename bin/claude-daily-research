#!/bin/bash
# claude-daily-research: Claude Code 생태계 변화 리서치 + AI 평가 + 텔레그램 브리핑.
# 2026-05-12 재작성: claude --bare 호출 제거 (Max OAuth 실패로 abort 사고).
# 구조: curl 기반 search → ai-debate (codex+gemini) 평가 → 텔레그램 전송.

set -uo pipefail

export NVM_DIR="$HOME/.nvm"
set +u
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
set -u
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

TELEGRAM_ENV="/home/gmoh/test_claude/.claude/telegram/.env"
CHAT_ID="8689118207"
DATA_DIR="$HOME/.local/share/ai-briefing"
TODAY="$(date +%Y-%m-%d)"
SEVEN_DAYS_AGO="$(date -u -d '7 days ago' +%Y-%m-%dT%H:%M:%SZ)"
RUN_ID="$(date +%Y%m%dT%H%M%SZ)"
OUT_FILE="$DATA_DIR/claude-research_${TODAY}.md"
LOG_FILE="$DATA_DIR/claude-research.log"
BRIEFING_DIR="$HOME/.claude/state/briefings"
BRIEFING_FILE="$BRIEFING_DIR/${TODAY}.md"
STATUS_DIR="$HOME/.local/state/claude-daily-research"
STATUS_FILE="$STATUS_DIR/status.jsonl"

mkdir -p "$DATA_DIR" "$BRIEFING_DIR" "$STATUS_DIR"
[ -f "$TELEGRAM_ENV" ] && source "$TELEGRAM_ENV"
BOT_TOKEN="${TELEGRAM_BOT_TOKEN:-${BOT_TOKEN:-}}"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"; }

status() {
    # phase, success(true/false), extra json fragment
    local phase="$1" success="$2" extra="${3:-}"
    local now; now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    jq -nc \
        --arg ts "$now" \
        --arg rid "$RUN_ID" \
        --arg ph "$phase" \
        --argjson ok "$success" \
        "{ts:\$ts, run_id:\$rid, phase:\$ph, success:\$ok ${extra:+, $extra}}" \
        >> "$STATUS_FILE" 2>/dev/null
}

abort() {
    local phase="$1" reason="$2"
    log "ABORT phase=$phase reason=$reason"
    status "$phase" false "error_kind:\"$reason\""
    exit 1
}

log "start run_id=$RUN_ID since=$SEVEN_DAYS_AGO"
status start true ""

# ── 1. curl 기반 search: GitHub releases (deterministic, no AI auth needed) ──
REPOS=(
    "anthropics/claude-code"
    "anthropics/anthropic-sdk-python"
    "anthropics/anthropic-sdk-typescript"
    "anthropics/anthropic-quickstarts"
    "anthropics/claude-agent-sdk-python"
    "anthropics/claude-agent-sdk-typescript"
)

CANDIDATES_FILE="$(mktemp)"
trap "rm -f $CANDIDATES_FILE" EXIT

candidate_count=0
for repo in "${REPOS[@]}"; do
    # GitHub releases API. unauth limit 60/h - 6 repos OK.
    resp=$(curl -sS --max-time 20 \
        -H "Accept: application/vnd.github+json" \
        "https://api.github.com/repos/${repo}/releases?per_page=10" 2>/dev/null || echo "[]")
    [ -z "$resp" ] && continue
    # Filter published_at >= 7d ago
    items=$(echo "$resp" | jq -c --arg since "$SEVEN_DAYS_AGO" --arg r "$repo" \
        '[ .[] | select(.published_at >= $since) | {repo:$r, tag:.tag_name, name:.name, url:.html_url, published:.published_at, body:(.body // "" | .[0:400])} ]' 2>/dev/null || echo "[]")
    cnt=$(echo "$items" | jq 'length' 2>/dev/null || echo 0)
    if [ "$cnt" -gt 0 ]; then
        echo "$items" | jq -c '.[]' >> "$CANDIDATES_FILE"
        candidate_count=$((candidate_count + cnt))
        log "  $repo: $cnt new releases"
    fi
done

# Anthropic news (HTML scrape, fragile but cheap). 최근 4건만.
news_html=$(curl -sS --max-time 15 "https://www.anthropic.com/news" 2>/dev/null || echo "")
if [ -n "$news_html" ]; then
    # 간단 추출: /news/ 링크 + 텍스트.
    echo "$news_html" \
        | grep -oE 'href="/news/[^"]+"[^>]*>[^<]+' \
        | head -8 \
        | while read -r line; do
            href=$(echo "$line" | sed -E 's|href="([^"]+)".*|\1|')
            title=$(echo "$line" | sed -E 's|.*>||')
            [ -z "$href" ] || [ -z "$title" ] && continue
            jq -nc --arg r "anthropic-news" --arg u "https://www.anthropic.com${href}" --arg t "$title" \
                '{repo:$r, tag:"", name:$t, url:$u, published:"", body:""}'
        done >> "$CANDIDATES_FILE"
    extra=$(grep -c '"repo":"anthropic-news"' "$CANDIDATES_FILE" 2>/dev/null | head -1 | tr -dc '0-9')
    [ -z "$extra" ] && extra=0
    candidate_count=$((candidate_count + extra))
    log "  anthropic news: $extra titles"
fi

log "search done: $candidate_count candidates"
status search true "candidate_count:$candidate_count"

if [ "$candidate_count" -lt 1 ]; then
    abort search "no_candidates"
fi

# ── 2. ai-debate 평가 호출 ──
CANDIDATES_JSON=$(cat "$CANDIDATES_FILE")

DEBATE_TASK="아래는 지난 7일 내 anthropics GitHub release 와 anthropic.com/news 에서 자동 수집한 Claude Code 생태계 변화 후보다. 각 후보를 평가해 운영자에게 보낼 한국어 평문 브리핑을 작성하라.

평가 기준
- 도입 / 보류 / 비추 + 이유 1줄.
- 적용 난이도 (쉬움/중간/어려움).
- 사용자 환경: Ubuntu, Claude Code 2.1, systemd 9개 세션, 텔레그램 remote-control, lean-ctx·telegram·code-review·scientific-writer 플러그인, ai-collaborate·paper-fit·loop·schedule 스킬, dotfiles 관리, Claude Max + Opus 4.7 (1M).
- 사고 가드(prompt-length / large-read / secrets-scan / rate-limit / drift / stuck-loop / bash-latency) 와 충돌 가능성 표시.

출력 형식 (평문, 한국어, 한 덩어리)
- 백틱·코드펜스·**굵게** 금지. 들여쓰기·맨앞 공백 금지.
- 후보 하나당 3~5줄: 제목, URL, 날짜, 핵심 변화, 도입 판정 + 이유, 난이도.
- 마지막에 '오늘 도입 추천 1건' 또는 '오늘 도입 추천 없음' + 사유.

후보 (JSON lines):
${CANDIDATES_JSON}"

log "ai-debate start"
DEBATE_OUT=$(timeout 1200 ai-debate --no-cache --max-rounds 1 "$DEBATE_TASK" 2>> "$LOG_FILE") || true
log "ai-debate exit. length=${#DEBATE_OUT}"

if [ "${#DEBATE_OUT}" -lt 500 ]; then
    abort ai_debate "short_output_len_${#DEBATE_OUT}"
fi

# arbiter FINAL 섹션 추출 (없으면 전체 사용).
OUTPUT=$(echo "$DEBATE_OUT" | awk '/^--- ARBITER/{flag=1} flag{print}' )
[ -z "$OUTPUT" ] && OUTPUT="$DEBATE_OUT"

# URL 가드: 본문 안에 http 링크 ≥ 3.
url_count=$(echo "$OUTPUT" | grep -oE 'https?://[^ )"]+' | sort -u | wc -l)
log "url_count=$url_count"
if [ "$url_count" -lt 3 ]; then
    abort guard "url_count_${url_count}"
fi

status ai_debate true "candidate_count:$candidate_count,url_count:$url_count,output_bytes:${#OUTPUT}"

# ── 3. 저장 ──
{
    echo "# Claude Code 개선 리서치 ${TODAY}"
    echo "run_id: $RUN_ID"
    echo "후보 수: $candidate_count"
    echo "URL 수: $url_count"
    echo
    echo "$OUTPUT"
} > "$OUT_FILE"
cp "$OUT_FILE" "$BRIEFING_FILE"

# ── 4. 텔레그램 전송 (3500자 chunk) ──
if [ "${SMOKE:-0}" = "1" ]; then
    log "SMOKE=1, telegram step skipped"
    status smoke_done true "candidate_count:$candidate_count,url_count:$url_count,output_bytes:${#OUTPUT}"
    exit 0
fi
if [ -z "$BOT_TOKEN" ]; then
    abort telegram "no_token"
fi

HEADER="Claude Code 개선 리서치 ${TODAY}
후보 ${candidate_count}건, URL ${url_count}개. 다음 SessionStart 시 컨텍스트 자동 흡수.

"
FULL_MSG="${HEADER}${OUTPUT}"

# 3500자 단위 split (utf-8 안전: awk)
TMP_SPLIT=$(mktemp -d)
echo "$FULL_MSG" | awk -v size=3500 -v dir="$TMP_SPLIT" '
{
    buf = buf $0 "\n"
    while (length(buf) >= size) {
        cut = size
        while (cut > 0 && substr(buf, cut, 1) != "\n" && substr(buf, cut, 1) != " ") cut--
        if (cut <= 0) cut = size
        chunk_num++
        f = sprintf("%s/c%03d", dir, chunk_num)
        print substr(buf, 1, cut) > f
        close(f)
        buf = substr(buf, cut + 1)
    }
}
END {
    if (length(buf) > 0) {
        chunk_num++
        f = sprintf("%s/c%03d", dir, chunk_num)
        print buf > f
        close(f)
    }
}'

chunk_files=($(ls "$TMP_SPLIT"/c* 2>/dev/null | sort))
total=${#chunk_files[@]}
sent=0
for i in "${!chunk_files[@]}"; do
    n=$((i + 1))
    label=""
    [ "$total" -gt 1 ] && label="[${n}/${total}] "
    body=$(cat "${chunk_files[$i]}")
    curl -sS --max-time 30 -X POST \
        "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" \
        --data-urlencode "chat_id=${CHAT_ID}" \
        --data-urlencode "text=${label}${body}" \
        --data-urlencode "disable_web_page_preview=true" >> "$LOG_FILE" 2>&1
    rc=$?
    if [ $rc -eq 0 ]; then sent=$((sent + 1)); fi
    sleep 1
done
rm -rf "$TMP_SPLIT"

log "telegram sent=$sent/$total bytes=${#FULL_MSG}"
status telegram true "messages:$sent,bytes:${#FULL_MSG}"

if [ "$sent" -lt "$total" ]; then
    abort telegram "partial_send_${sent}_of_${total}"
fi

status done true "candidate_count:$candidate_count,url_count:$url_count,messages:$total"
log "complete"
exit 0
