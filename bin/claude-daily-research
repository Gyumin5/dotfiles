#!/bin/bash
# claude-daily-research: Claude Code 생태계 변화 리서치 + AI 평가 + 텔레그램 브리핑.
# 2026-05-12 재작성: claude --bare 호출 제거 (Max OAuth 실패로 abort 사고).
# 구조: curl 기반 search → ai-debate (codex+gemini) 평가 → 텔레그램 전송.

set -uo pipefail

export NVM_DIR="$HOME/.nvm"
set +u
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"
set -u
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

TELEGRAM_ENV="/home/gmoh/dotfiles/.claude/telegram/.env"
CHAT_ID="8689118207"
DATA_DIR="$HOME/.local/share/ai-briefing"
TODAY="$(date +%Y-%m-%d)"
SEVEN_DAYS_AGO="$(date -u -d '7 days ago' +%Y-%m-%dT%H:%M:%SZ)"
RUN_ID="$(date +%Y%m%dT%H%M%SZ)"
OUT_FILE="$DATA_DIR/claude-research_${TODAY}.md"
LOG_FILE="$DATA_DIR/claude-research.log"
BRIEFING_DIR="$HOME/.claude/state/briefings"
BRIEFING_FILE="$BRIEFING_DIR/${TODAY}.md"
STATUS_DIR="$HOME/.local/state/claude-daily-research"
STATUS_FILE="$STATUS_DIR/status.jsonl"

mkdir -p "$DATA_DIR" "$BRIEFING_DIR" "$STATUS_DIR"
[ -f "$TELEGRAM_ENV" ] && source "$TELEGRAM_ENV"
BOT_TOKEN="${TELEGRAM_BOT_TOKEN:-${BOT_TOKEN:-}}"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"; }

status() {
    # phase, success(true/false), extra json fragment
    local phase="$1" success="$2" extra="${3:-}"
    local now; now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    jq -nc \
        --arg ts "$now" \
        --arg rid "$RUN_ID" \
        --arg ph "$phase" \
        --argjson ok "$success" \
        "{ts:\$ts, run_id:\$rid, phase:\$ph, success:\$ok ${extra:+, $extra}}" \
        >> "$STATUS_FILE" 2>/dev/null
}

abort() {
    local phase="$1" reason="$2"
    log "ABORT phase=$phase reason=$reason"
    status "$phase" false "error_kind:\"$reason\""
    exit 1
}

log "start run_id=$RUN_ID since=$SEVEN_DAYS_AGO"
status start true ""

# ── 1. curl 기반 search: 인터넷 유행 기술 일반 (HN + GitHub trending + arXiv) ──
# 2026-05-14 변경: anthropics/* 추적은 어차피 auto-upgrade라 무의미 (사용자 요청).
# 대신 인터넷에서 유행하는 기술/논문 전반을 수집.
CANDIDATES_FILE="$(mktemp)"
trap "rm -f $CANDIDATES_FILE" EXIT

candidate_count=0

# 1a) HackerNews — Algolia search, 지난 7일 인기 top 20
# > 가 URL에서 안전하므로 %3E로 인코딩
HN_SINCE=$(date -d '7 days ago' +%s)
hn_resp=$(curl -sS --max-time 25 -G \
    --data-urlencode "tags=story" \
    --data-urlencode "numericFilters=created_at_i>${HN_SINCE},points>100" \
    --data-urlencode "hitsPerPage=10" \
    "https://hn.algolia.com/api/v1/search" 2>/dev/null || echo "")
if [ -n "$hn_resp" ]; then
    hn_items=$(echo "$hn_resp" | jq -c \
        '[ .hits[]? | select(.url != null and (.points // 0) >= 100) | {source:"hackernews", title:.title, url:.url, points:.points, published:.created_at, body:""} ]' 2>/dev/null || echo "[]")
    hn_cnt=$(echo "$hn_items" | jq 'length' 2>/dev/null || echo 0)
    if [ "$hn_cnt" -gt 0 ]; then
        echo "$hn_items" | jq -c '.[]' >> "$CANDIDATES_FILE"
        candidate_count=$((candidate_count + hn_cnt))
        log "  hackernews: $hn_cnt items"
    fi
fi

# 1b) GitHub trending — weekly top, 언어별. python으로 robust parse (필터 URL 제외).
gh_added_count=0
for lang in "" "python" "rust" "typescript"; do
    url="https://github.com/trending"
    [ -n "$lang" ] && url="$url/$lang"
    url="$url?since=weekly"
    gh_html=$(curl -sS --max-time 20 -A "Mozilla/5.0 (compatible; daily-research/1.0)" "$url" 2>/dev/null || echo "")
    [ -z "$gh_html" ] && continue
    parsed=$(echo "$gh_html" | python3 -c "
import sys, re, json
html = sys.stdin.read()
# 구조: <h2 class='h3 lh-condensed'><a href='/owner/repo' ...>
pattern = re.compile(r'<h2[^>]*class=\"[^\"]*lh-condensed[^\"]*\"[^>]*>\s*<a[^>]+href=\"(/[^/\"]+/[^/\"?]+)\"', re.S)
seen = set()
items = []
for m in pattern.finditer(html):
    path = m.group(1).strip()
    if path.startswith('/trending') or path in seen:
        continue
    seen.add(path)
    items.append(path)
    if len(items) >= 3: break
for p in items:
    print(json.dumps({'source':'github-trending','title':'github-trending: '+p,'url':'https://github.com'+p,'lang':'${lang}' or 'mixed','published':'','body':''}, ensure_ascii=False))
" 2>/dev/null || echo "")
    if [ -n "$parsed" ]; then
        echo "$parsed" >> "$CANDIDATES_FILE"
        n=$(echo "$parsed" | wc -l)
        gh_added_count=$((gh_added_count + n))
    fi
done
candidate_count=$((candidate_count + gh_added_count))
log "  github-trending: $gh_added_count repos (lang별 weekly top)"

# 1c) arXiv 최신 cs.AI / cs.LG / cs.RO — atom feed, python parse
arxiv_added_count=0
for cat in "cs.AI" "cs.LG" "cs.RO"; do
    arxiv_resp=$(curl -sS --max-time 20 \
        "https://export.arxiv.org/api/query?search_query=cat:${cat}&sortBy=submittedDate&sortOrder=descending&max_results=3" 2>/dev/null || echo "")
    [ -z "$arxiv_resp" ] && continue
    parsed=$(echo "$arxiv_resp" | python3 -c "
import sys, re, json
buf = sys.stdin.read()
entries = re.findall(r'<entry>(.*?)</entry>', buf, re.S)
for e in entries:
    tm = re.search(r'<title>(.*?)</title>', e, re.S)
    im = re.search(r'<id>(.*?)</id>', e, re.S)
    pm = re.search(r'<published>(.*?)</published>', e, re.S)
    sm = re.search(r'<summary>(.*?)</summary>', e, re.S)
    if tm and im:
        print(json.dumps({
            'source':'arxiv-${cat}',
            'title':' '.join(tm.group(1).split()),
            'url':im.group(1).strip(),
            'published':(pm.group(1).strip() if pm else ''),
            'body':' '.join((sm.group(1) if sm else '').split())[:300]
        }, ensure_ascii=False))
" 2>/dev/null || echo "")
    if [ -n "$parsed" ]; then
        echo "$parsed" >> "$CANDIDATES_FILE"
        n=$(echo "$parsed" | wc -l)
        arxiv_added_count=$((arxiv_added_count + n))
    fi
done
candidate_count=$((candidate_count + arxiv_added_count))
log "  arxiv: $arxiv_added_count papers (cs.AI/LG/RO 최신)"

log "search done: $candidate_count candidates"
status search true "candidate_count:$candidate_count"

if [ "$candidate_count" -lt 1 ]; then
    abort search "no_candidates"
fi

# ── 2. ai-debate 평가 호출 ──
CANDIDATES_JSON=$(cat "$CANDIDATES_FILE")

DEBATE_TASK="아래는 지난 7일 화제가 된 기술/논문 후보 (HN, GitHub trending, arXiv cs.AI/LG/RO). 운영자 맥락: AV/SLAM 연구, ROS, 9개 Claude Code 세션, dotfiles 관리, 논문 작성.

목표: 후보 카탈로그 나열 금지. 토론·합의 끝에 운영자가 이번 주 실제로 해야 할 단 1건만 결정. 없으면 '이번 주 변경 없음' 으로 결론.

작업 방식 (엄격)
- 모든 후보를 내부적으로 평가. 본문에 카탈로그·후보 리스트·운영자 의미·번호 매기기 금지.
- 토론으로 1건 결정 (또는 변경 없음 결정).
- 1건이 선정되면 그게 무엇이고, 왜 지금 필요하며, 무엇을 어떻게 해야 하는지를 운영자가 바로 실행할 수준의 구체 명령으로 제공.
- '검토 후 적용' 같은 모호한 행동 금지. 실행 명령 또는 '실행 불필요' 결정.

출력 형식 (평문 한국어, 1200자 이내, 한 덩어리)
- 백틱·코드펜스·굵게·들여쓰기·번호 매기기 금지.
- 첫 줄: '이번 주 트렌드: <1문장>'
- 둘째 줄 빈 줄.
- '결정: <도입할 것 또는 변경 없음>'
- '이유: <왜 이번 주에 필요한지 2~3문장. 운영자 현 워크플로우와 직접 연결>'
- '실행: <bash 명령 또는 구체 단계 1~3줄, 복붙 가능 형식>' 또는 '실행 불필요'
- '위험: <이 행동의 리스크 1문장 또는 없으면 생략>'
- '검증: <어떻게 효과 확인할지 1문장>'
- '출처: <URL 1개, 결정 근거가 된 후보>'

규칙
- 결정이 '변경 없음' 이면 이유·검증·출처 모두 채우되 실행/위험 생략.
- 출처 URL 1개만. 카탈로그 링크 나열 금지.
- 후보가 stars 5 미만, license 불명, 운영 무관이면 결정 후보에서 제외.

후보 (JSON lines):
${CANDIDATES_JSON}"

log "ai-debate start"
DEBATE_OUT=$(timeout 1200 ai-debate --no-cache --max-rounds 1 "$DEBATE_TASK" 2>> "$LOG_FILE") || true
log "ai-debate exit. length=${#DEBATE_OUT}"

if [ "${#DEBATE_OUT}" -lt 200 ]; then
    abort ai_debate "short_output_len_${#DEBATE_OUT}"
fi

# arbiter 다중 필드를 단일 결정 형식으로 조립.
# arbiter JSON 스키마는 final_decision(1줄 헤드라인) + rationale + action_steps + risks + verification_plan 분리.
# 새 형식: 트렌드/결정/이유/실행/위험/검증/출처 한 덩어리.
ARB_RUN_DIR=$(echo "$DEBATE_OUT" | awk '/^artifacts=/{sub("artifacts=",""); print; exit}')
OUTPUT=""
if [ -n "$ARB_RUN_DIR" ] && [ -f "$ARB_RUN_DIR/arbiter.normalized.json" ]; then
    ARB_JSON="$ARB_RUN_DIR/arbiter.normalized.json"
    DECISION=$(jq -r '.final_decision // ""' "$ARB_JSON" 2>/dev/null)
    RATIONALE=$(jq -r '.rationale // ""' "$ARB_JSON" 2>/dev/null)
    ACTION=$(jq -r '.action_steps // ""' "$ARB_JSON" 2>/dev/null)
    RISKS=$(jq -r '.risks // ""' "$ARB_JSON" 2>/dev/null)
    VERIFY=$(jq -r '.verification_plan // ""' "$ARB_JSON" 2>/dev/null)

    # 후보 중 rationale·decision 본문에 title 토큰 가장 많이 매칭되는 1건 URL 선정.
    SOURCE_URL=$(BODY="${DECISION}
${RATIONALE}
${ACTION}" CAND_FILE="$CANDIDATES_FILE" python3 - <<'PY' 2>/dev/null
import json, os, re
body = os.environ.get("BODY", "").lower()
best_url = ""
best_score = 0
with open(os.environ["CAND_FILE"]) as f:
    for line in f:
        try:
            c = json.loads(line)
        except Exception:
            continue
        title = (c.get("title") or "").lower()
        url = c.get("url") or ""
        if not url:
            continue
        tokens = [t for t in re.split(r"[\s/:._\-]+", title) if len(t) >= 4]
        if not tokens:
            continue
        score = sum(1 for t in tokens if t in body)
        if score > best_score:
            best_score = score
            best_url = url
print(best_url)
PY
)

    {
        echo "이번 주 트렌드: ${DECISION}"
        echo
        echo "결정: ${DECISION}"
        [ -n "$RATIONALE" ] && echo "이유: ${RATIONALE}"
        [ -n "$ACTION" ] && echo "실행:"
        [ -n "$ACTION" ] && echo "${ACTION}"
        [ -n "$RISKS" ] && echo "위험: ${RISKS}"
        [ -n "$VERIFY" ] && echo "검증: ${VERIFY}"
        [ -n "$SOURCE_URL" ] && echo "출처: ${SOURCE_URL}"
    } > "$ARB_RUN_DIR/_assembled.txt"
    OUTPUT=$(cat "$ARB_RUN_DIR/_assembled.txt")
fi
# fallback: stdout 전체 (구버전 호환)
if [ -z "$OUTPUT" ]; then
    OUTPUT=$(echo "$DEBATE_OUT" | awk '/^--- ARBITER/{flag=1} flag{print}')
fi
[ -z "$OUTPUT" ] && OUTPUT="$DEBATE_OUT"

# URL 가드: 단일 결정 형식에서는 0건 허용 (변경 없음 결정이면 URL 없을 수 있음).
url_count=$(echo "$OUTPUT" | grep -oE 'https?://[^ )"]+' | sort -u | wc -l)
log "url_count=$url_count"

status ai_debate true "candidate_count:$candidate_count,url_count:$url_count,output_bytes:${#OUTPUT}"

# ── 3. 저장 ──
{
    echo "# Claude Code 개선 리서치 ${TODAY}"
    echo "run_id: $RUN_ID"
    echo "후보 수: $candidate_count"
    echo "URL 수: $url_count"
    echo
    echo "$OUTPUT"
} > "$OUT_FILE"
cp "$OUT_FILE" "$BRIEFING_FILE"

# ── 4. 텔레그램 전송 (3500자 chunk) ──
if [ "${SMOKE:-0}" = "1" ]; then
    log "SMOKE=1, telegram step skipped"
    status smoke_done true "candidate_count:$candidate_count,url_count:$url_count,output_bytes:${#OUTPUT}"
    exit 0
fi
if [ -z "$BOT_TOKEN" ]; then
    abort telegram "no_token"
fi

HEADER="일일 리서치 ${TODAY} (후보 ${candidate_count}건 평가)

"
FULL_MSG="${HEADER}${OUTPUT}"

# 3500자 단위 split (utf-8 안전: awk)
TMP_SPLIT=$(mktemp -d)
echo "$FULL_MSG" | awk -v size=3500 -v dir="$TMP_SPLIT" '
{
    buf = buf $0 "\n"
    while (length(buf) >= size) {
        cut = size
        while (cut > 0 && substr(buf, cut, 1) != "\n" && substr(buf, cut, 1) != " ") cut--
        if (cut <= 0) cut = size
        chunk_num++
        f = sprintf("%s/c%03d", dir, chunk_num)
        print substr(buf, 1, cut) > f
        close(f)
        buf = substr(buf, cut + 1)
    }
}
END {
    if (length(buf) > 0) {
        chunk_num++
        f = sprintf("%s/c%03d", dir, chunk_num)
        print buf > f
        close(f)
    }
}'

chunk_files=($(ls "$TMP_SPLIT"/c* 2>/dev/null | sort))
total=${#chunk_files[@]}
sent=0
for i in "${!chunk_files[@]}"; do
    n=$((i + 1))
    label=""
    [ "$total" -gt 1 ] && label="[${n}/${total}] "
    body=$(cat "${chunk_files[$i]}")
    curl -sS --max-time 30 -X POST \
        "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" \
        --data-urlencode "chat_id=${CHAT_ID}" \
        --data-urlencode "text=${label}${body}" \
        --data-urlencode "disable_web_page_preview=true" >> "$LOG_FILE" 2>&1
    rc=$?
    if [ $rc -eq 0 ]; then sent=$((sent + 1)); fi
    sleep 1
done
rm -rf "$TMP_SPLIT"

log "telegram sent=$sent/$total bytes=${#FULL_MSG}"
status telegram true "messages:$sent,bytes:${#FULL_MSG}"

if [ "$sent" -lt "$total" ]; then
    abort telegram "partial_send_${sent}_of_${total}"
fi

status done true "candidate_count:$candidate_count,url_count:$url_count,messages:$total"
log "complete"
exit 0
