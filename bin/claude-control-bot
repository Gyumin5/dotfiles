#!/usr/bin/env python3
"""
claude-control-bot: 텔레그램 봇으로 claude-sessions (cs) 명령 원격 실행.
Long-polling 기반, 단일 계정 화이트리스트, Inline Keyboard UX.

env 파일: ~/.claude/control-bot/.env
  CONTROL_BOT_TOKEN=...
  ALLOWED_USER_ID=...

systemd user service로 상시 실행.
"""
import json
import os
import subprocess
import time
import urllib.request
import urllib.parse
from pathlib import Path

ENV_PATH = Path.home() / ".claude" / "control-bot" / ".env"


def load_env():
    env = {}
    if ENV_PATH.exists():
        for line in ENV_PATH.read_text().splitlines():
            if "=" in line and not line.startswith("#"):
                k, v = line.split("=", 1)
                env[k.strip()] = v.strip()
    return env


env = load_env()
TOKEN = env.get("CONTROL_BOT_TOKEN", "")
ALLOWED_USER = int(env.get("ALLOWED_USER_ID", "0"))
if not TOKEN or not ALLOWED_USER:
    raise SystemExit("CONTROL_BOT_TOKEN / ALLOWED_USER_ID missing in .env")

API = f"https://api.telegram.org/bot{TOKEN}"


def api(method, **params):
    data = urllib.parse.urlencode({k: (json.dumps(v) if isinstance(v, (dict, list)) else v) for k, v in params.items()}).encode()
    try:
        with urllib.request.urlopen(f"{API}/{method}", data=data, timeout=60) as r:
            return json.loads(r.read())
    except Exception as e:
        print(f"[api {method}] {e}", flush=True)
        return {"ok": False, "description": str(e)}


def list_sessions():
    """enabled claude-*.service 목록에서 세션 이름 추출"""
    try:
        out = subprocess.check_output(
            ["systemctl", "--user", "list-unit-files", "claude-*.service", "--state=enabled", "--no-legend"],
            text=True, timeout=5,
        )
        names = []
        for line in out.splitlines():
            unit = line.strip().split()[0] if line.strip() else ""
            if not unit:
                continue
            if unit in ("claude-watchdog.service", "claude-control-bot.service",
                        "claude-progress-updater.service", "claude-progress-updater-all.service",
                        "claude-rate-limit-recovery.service", "claude-daily-research.service"):
                continue
            # claude-*.service 중 Claude Code 세션이 아닌 보조 서비스 제외
            if unit.startswith("claude-progress") or unit.startswith("claude-rate-limit") or unit.startswith("claude-daily"):
                continue
            # claude-<name>.service → <name>
            name = unit[len("claude-"):-len(".service")]
            names.append(name)
        return sorted(names)
    except Exception as e:
        print(f"[list_sessions] {e}", flush=True)
        return []


def run_cs(*args, timeout=30):
    """cs (claude-sessions) 실행. stdout 반환."""
    try:
        out = subprocess.check_output(
            ["/home/gmoh/.local/bin/claude-sessions", *args],
            text=True, stderr=subprocess.STDOUT, timeout=timeout,
        )
        return out.strip()[:3500]  # Telegram 4096 제한 여유
    except subprocess.TimeoutExpired:
        return "[timeout]"
    except subprocess.CalledProcessError as e:
        return f"[error exit {e.returncode}]\n{e.output[:3000]}"
    except Exception as e:
        return f"[exception] {e}"


def main_menu_markup():
    return {"inline_keyboard": [
        [{"text": "📊 Status", "callback_data": "status"},
         {"text": "💻 Resources", "callback_data": "resources"}],
        [{"text": "🚧 Bypass…", "callback_data": "menu:bypass"},
         {"text": "📜 Recent…", "callback_data": "menu:recent"}],
        [{"text": "🔄 Restart…", "callback_data": "menu:restart"}],
    ]}


def _fmt_gb(b):
    return f"{b/1024/1024/1024:.1f}G"


def _pct_emoji(pct, warn, danger):
    if pct >= danger: return "🔴"
    if pct >= warn: return "⚠️"
    return "✅"


def read_resources():
    """단일 화면(≤20줄) 리소스 요약. 사고 조기 신호 우선.
    포함: uptime, load, CPU%, MEM, swap, disk(/, /mnt/Data), 9세션 active/RSS,
    bun 누락, 1h OOM, 1h restart."""
    lines = []
    try:
        # uptime + load
        with open("/proc/uptime") as f:
            up_sec = int(float(f.read().split()[0]))
        d, rem = divmod(up_sec, 86400); h, rem = divmod(rem, 3600); m, _ = divmod(rem, 60)
        with open("/proc/loadavg") as f:
            la = f.read().split()[:3]
        ncpu = os.cpu_count() or 1
        la_em = _pct_emoji(float(la[0]) / ncpu * 100, 70, 100)
        lines.append(f"⏱ up {d}d{h}h{m}m | load {la_em} {la[0]}/{la[1]}/{la[2]} (cpu={ncpu})")

        # CPU% (1초 샘플)
        def _cpu():
            with open("/proc/stat") as f:
                p = f.readline().split()[1:8]
            t = list(map(int, p)); return sum(t), t[3]
        t1, i1 = _cpu(); time.sleep(0.5); t2, i2 = _cpu()
        cpu_pct = int(round((1 - (i2-i1)/max(1, t2-t1)) * 100))
        lines.append(f"{_pct_emoji(cpu_pct, 70, 90)} CPU {cpu_pct}%")

        # MEM / swap
        mi = {}
        with open("/proc/meminfo") as f:
            for ln in f:
                k, v = ln.split(":", 1)
                mi[k] = int(v.strip().split()[0]) * 1024
        used = mi["MemTotal"] - mi["MemAvailable"]
        mem_pct = int(round(used / mi["MemTotal"] * 100))
        swap_used = mi.get("SwapTotal", 0) - mi.get("SwapFree", 0)
        swap_pct = int(round(swap_used / mi["SwapTotal"] * 100)) if mi.get("SwapTotal") else 0
        sw_em = _pct_emoji(swap_pct, 30, 60)
        lines.append(f"{_pct_emoji(mem_pct, 70, 85)} MEM {mem_pct}% ({_fmt_gb(used)}/{_fmt_gb(mi['MemTotal'])}) | {sw_em} swap {swap_pct}% ({_fmt_gb(swap_used)})")

        # Disk
        for mp, label in [("/", "/"), ("/mnt/Data", "/mnt/Data")]:
            try:
                st = os.statvfs(mp)
                total = st.f_blocks * st.f_frsize
                free = st.f_bavail * st.f_frsize
                used_p = int(round((1 - free/total) * 100))
                lines.append(f"{_pct_emoji(used_p, 80, 90)} disk {label} {used_p}% (free {_fmt_gb(free)})")
            except Exception:
                pass

        # Claude services
        names = list_sessions()
        active = failed = bun_missing = 0
        rss_list = []
        for n in names:
            ok, bun = session_health(n)
            if ok: active += 1
            else: failed += 1
            if ok and not bun: bun_missing += 1
            # RSS (cgroup memory.current 우선)
            for cp in (f"/sys/fs/cgroup/user.slice/user-1000.slice/user@1000.service/claude-{n}.service/memory.current",):
                try:
                    rss_list.append((n, int(open(cp).read().strip())))
                    break
                except Exception:
                    pass
        rss_total = sum(r for _, r in rss_list)
        svc_em = "🔴" if failed else ("⚠️" if bun_missing else "✅")
        lines.append(f"{svc_em} claude svc {active}/{len(names)} active, failed={failed}, bun_missing={bun_missing}")
        if rss_list:
            top = sorted(rss_list, key=lambda x: -x[1])[:3]
            top_s = " ".join(f"{n}={_fmt_gb(r)}" for n, r in top)
            lines.append(f"  RSS total {_fmt_gb(rss_total)} | top: {top_s}")

        # 1h OOM + restart
        try:
            oom_out = subprocess.run(
                ["journalctl", "--user", "--since", "1 hour ago", "-q"],
                capture_output=True, text=True, timeout=10,
            ).stdout
            oom = sum(1 for ln in oom_out.splitlines() if "oom-killer" in ln.lower() or "out of memory" in ln.lower())
            restart = sum(1 for ln in oom_out.splitlines() if "claude-" in ln and "Started" in ln)
            oom_em = "🔴" if oom else "✅"
            rs_em = "⚠️" if restart > 2 else "✅"
            lines.append(f"{oom_em} 1h OOM={oom} | {rs_em} restart={restart}")
        except Exception:
            pass

        lines.append(f"\n_{time.strftime('%Y-%m-%d %H:%M:%S KST')}_")
    except Exception as e:
        lines.append(f"[resources error] {e}")
    return "\n".join(lines)


BYPASS_DIR = Path.home() / ".claude" / "state"
BYPASS_GLOBAL = BYPASS_DIR / "rate-limit-bypass.flag"


def bypass_proj_flag(name):
    # 세션 키 = systemd unit의 CLAUDE_SESSION_NAME (=서비스 이름의 'claude-' 접두 제거).
    # 모든 hook도 같은 키 사용 → cwd 변경/cd 들어가도 일관성.
    return BYPASS_DIR / f"rate-limit-bypass-{name}.flag", name


THRESHOLD_5H = 90
THRESHOLD_7D = 99


def current_rate_limits():
    """statusline_cache 기반 (5h%, 7d%, 5h_reset_str, 7d_reset_str, blocked_now)"""
    try:
        from datetime import datetime, timezone, timedelta
        kst = timezone(timedelta(hours=9))
        path = Path.home() / ".claude" / "statusline_cache.json"
        d = json.loads(path.read_text())
        rl = d.get("rate_limits", {})
        fh = rl.get("five_hour", {}) or {}
        sd = rl.get("seven_day", {}) or {}
        now = time.time()
        def eff(w):
            rt = w.get("resets_at")
            if rt and now > rt:
                return 0
            v = w.get("used_percentage")
            return int(round(v)) if isinstance(v, (int, float)) else -1
        p5, p7 = eff(fh), eff(sd)
        r5 = _fmt_reset(datetime.fromtimestamp(fh.get("resets_at", 0), tz=kst)) if fh.get("resets_at") else "?"
        r7 = _fmt_reset(datetime.fromtimestamp(sd.get("resets_at", 0), tz=kst)) if sd.get("resets_at") else "?"
        blocked = (p5 >= THRESHOLD_5H) or (p7 >= THRESHOLD_7D)
        return p5, p7, r5, r7, blocked
    except Exception:
        return -1, -1, "?", "?", False


def bypass_menu_text():
    p5, p7, r5, r7, blocked = current_rate_limits()
    head = (
        f"5h: {p5}% (리셋 {r5}) | 7d: {p7}% (리셋 {r7})\n"
        f"현재 가드 발동: {'🚫 YES' if blocked else '✅ NO'}\n\n"
        "각 세션 90% 가드 bypass 토글 (🟢=우회중, ⚪=가드 적용).\n"
        "리셋되면 bypass flag 자동 삭제됨.\n"
    )
    return head


def bypass_menu_markup():
    BYPASS_DIR.mkdir(parents=True, exist_ok=True)
    rows = []
    g_on = BYPASS_GLOBAL.exists()
    rows.append([{
        "text": f"{'🟢' if g_on else '⚪'} GLOBAL (전체)",
        "callback_data": "bypass-toggle:__global__",
    }])
    for name in list_sessions():
        info = bypass_proj_flag(name)
        if info is None:
            continue
        flag, proj = info
        on = flag.exists()
        rows.append([{
            "text": f"{'🟢' if on else '⚪'} {name} ({proj})",
            "callback_data": f"bypass-toggle:{name}",
        }])
    rows.append([{"text": "⬅ Back", "callback_data": "menu:main"}])
    return {"inline_keyboard": rows}


def service_workdir(name):
    """claude-<name>.service의 WorkingDirectory 읽기"""
    try:
        out = subprocess.check_output(
            ["systemctl", "--user", "show", f"claude-{name}.service", "-p", "WorkingDirectory", "--value"],
            text=True, timeout=5,
        ).strip()
        return out or None
    except Exception:
        return None


def project_key(workdir):
    """cwd → ~/.claude/projects/<key> 변환 (/와 _ 를 -로). Claude Code 명명 규칙과 일치."""
    return workdir.replace("/", "-").replace("_", "-")


def read_recent(name, max_turns=6, max_chars=3000):
    """세션의 최신 jsonl에서 마지막 user/assistant 텍스트 메시지 추출"""
    wd = service_workdir(name)
    if not wd:
        return f"[{name}] WorkingDirectory 못 찾음"
    proj = Path(f"{Path.home()}/.claude/projects/{project_key(wd)}")
    jsonls = sorted(proj.glob("*.jsonl"), key=lambda p: p.stat().st_mtime, reverse=True)
    if not jsonls:
        return f"[{name}] jsonl 없음 (proj={proj})"
    latest = jsonls[0]
    age = int(time.time() - latest.stat().st_mtime)
    # tail 200 lines
    try:
        with latest.open("rb") as f:
            f.seek(0, 2)
            size = f.tell()
            f.seek(max(0, size - 400_000))
            raw = f.read().decode("utf-8", errors="ignore")
    except Exception as e:
        return f"[{name}] read error: {e}"

    turns = []
    for line in raw.splitlines():
        try:
            d = json.loads(line)
        except Exception:
            continue
        t = d.get("type")
        ts = (d.get("timestamp", "") or "")[:19]
        msg = d.get("message", {}) or {}
        if t == "user":
            c = msg.get("content", "")
            if isinstance(c, str) and c.strip():
                turns.append(("U", ts, c.strip()))
        elif t == "assistant":
            c = msg.get("content", [])
            if isinstance(c, list):
                for item in c:
                    if isinstance(item, dict) and item.get("type") == "text":
                        txt = (item.get("text") or "").strip()
                        if txt:
                            turns.append(("A", ts, txt))

    turns = turns[-max_turns:]
    if not turns:
        return f"[{name}] 텍스트 턴 없음 (tool_use만?)\n마지막 활동: {age}s 전"

    lines = [f"[{name}] 마지막 활동: {age}s 전"]
    for role, ts, txt in turns:
        # 텔레그램 채널 태그 제거 간소화
        if "<channel " in txt:
            import re
            txt = re.sub(r"<channel [^>]+>", "", txt).replace("</channel>", "").strip()
        lines.append(f"\n{role}[{ts}]:\n{txt[:500]}")

    result = "\n".join(lines)
    return result[:max_chars]


_WD = ["월", "화", "수", "목", "금", "토", "일"]
def _fmt_reset(dt):
    return dt.strftime(f"%m/%d({_WD[dt.weekday()]}) %H:%M")


def _pct_to_int(v):
    """소수점 잡음(55.00000000000001 같은 부동소수) 제거. 항상 0~100 정수로."""
    if isinstance(v, (int, float)):
        return int(round(v))
    return None


def read_statusline():
    """rate-limit + 세션별 health 표시. ctx/cost/cache는 숨김."""
    try:
        path = Path.home() / ".claude" / "statusline_cache.json"
        d = json.loads(path.read_text())
        from datetime import datetime, timezone, timedelta
        kst = timezone(timedelta(hours=9))
        now = time.time()
        rl5 = d.get("rate_limits", {}).get("five_hour", {}) or {}
        rl7 = d.get("rate_limits", {}).get("seven_day", {}) or {}

        def eff_pct(w):
            rt = w.get("resets_at")
            if rt and now > rt:
                return 0
            return _pct_to_int(w.get("used_percentage"))

        p5, p7 = eff_pct(rl5), eff_pct(rl7)
        r5 = _fmt_reset(datetime.fromtimestamp(rl5.get("resets_at", 0), tz=kst)) if rl5.get("resets_at") else "?"
        r7 = _fmt_reset(datetime.fromtimestamp(rl7.get("resets_at", 0), tz=kst)) if rl7.get("resets_at") else "?"
        usage_lines = [
            f"5h: {p5 if p5 is not None else '?'}% (리셋 {r5})",
            f"7d: {p7 if p7 is not None else '?'}% (리셋 {r7})",
        ]

        health_lines = ["", "세션 / 텔레그램봇:"]
        for name in list_sessions():
            s_ok, bot_ok = session_health(name)
            s_icon = "🟢" if s_ok else "🔴"
            bot_icon = "🟢" if bot_ok else ("⚪" if s_ok else "🔴")
            health_lines.append(f"{s_icon} {name}  bot:{bot_icon}")
        return "\n".join(usage_lines + health_lines)
    except Exception as e:
        return f"[statusline read error] {e}"


def session_health(name):
    """(service_active, bun_alive) tuple. bun=텔레그램 MCP 자식."""
    unit = f"claude-{name}.service"
    try:
        active = subprocess.check_output(
            ["systemctl", "--user", "is-active", unit], text=True, timeout=3,
        ).strip() == "active"
    except Exception:
        active = False
    if not active:
        return False, False
    bun_alive = False
    cgroup_paths = [
        f"/sys/fs/cgroup/systemd/user.slice/user-1000.slice/user@1000.service/{unit}/cgroup.procs",
        f"/sys/fs/cgroup/user.slice/user-1000.slice/user@1000.service/{unit}/cgroup.procs",
    ]
    for cp in cgroup_paths:
        try:
            with open(cp) as f:
                for line in f:
                    pid = line.strip()
                    if not pid:
                        continue
                    try:
                        with open(f"/proc/{pid}/comm") as cf:
                            if cf.read().strip() == "bun":
                                bun_alive = True
                                break
                    except Exception:
                        continue
            if bun_alive:
                break
        except FileNotFoundError:
            continue
    return active, bun_alive


def session_menu_markup(action):
    """action: 'restart' (confirm 거침) 또는 'recent' (바로 실행)"""
    sessions = list_sessions()
    rows = []
    for i in range(0, len(sessions), 2):
        row = []
        for name in sessions[i:i+2]:
            if action == "restart":
                row.append({"text": name, "callback_data": f"confirm:{action}:{name}"})
            else:
                row.append({"text": name, "callback_data": f"{action}:{name}"})
        rows.append(row)
    if action == "restart":
        rows.append([{"text": "🔁 Restart All", "callback_data": "confirm:restart-all"}])
    rows.append([{"text": "⬅ Back", "callback_data": "menu:main"}])
    return {"inline_keyboard": rows}


def confirm_markup(action_data, label):
    """확인/취소 키보드. action_data가 확정 시 실행될 callback_data."""
    return {"inline_keyboard": [
        [{"text": f"✅ Yes ({label})", "callback_data": action_data},
         {"text": "❌ No", "callback_data": "menu:main"}],
    ]}


def show_main(chat_id, message_id=None):
    text = "Claude Session Control\n\n선택해주세요."
    if message_id:
        api("editMessageText", chat_id=chat_id, message_id=message_id, text=text, reply_markup=main_menu_markup())
    else:
        api("sendMessage", chat_id=chat_id, text=text, reply_markup=main_menu_markup())


def send_result_and_menu(chat_id, text):
    """실행 결과 텍스트 + 메인 메뉴 한꺼번에 전송"""
    api("sendMessage", chat_id=chat_id, text=text[:3500], reply_markup=main_menu_markup())


def handle_callback(cb):
    user_id = cb.get("from", {}).get("id", 0)
    if user_id != ALLOWED_USER:
        api("answerCallbackQuery", callback_query_id=cb["id"], text="unauthorized")
        return

    data = cb.get("data", "")
    msg = cb.get("message", {})
    chat_id = msg.get("chat", {}).get("id")
    message_id = msg.get("message_id")

    api("answerCallbackQuery", callback_query_id=cb["id"])

    if data == "list":
        out = run_cs("list")
        send_result_and_menu(chat_id, f"```\n{out}\n```")
    elif data == "status":
        out = read_statusline()
        send_result_and_menu(chat_id, out)
    elif data == "resources":
        out = read_resources()
        send_result_and_menu(chat_id, out)
    elif data == "restart-all":
        out = run_cs("restart-all", timeout=60)
        send_result_and_menu(chat_id, f"restart-all:\n{out}")
    elif data == "confirm:restart-all":
        api("editMessageText", chat_id=chat_id, message_id=message_id,
            text="⚠️ 모든 세션 재시작. 확실합니까?",
            reply_markup=confirm_markup("restart-all", "Restart All"))
    elif data.startswith("confirm:restart:"):
        name = data[len("confirm:restart:"):]
        api("editMessageText", chat_id=chat_id, message_id=message_id,
            text=f"⚠️ {name} 재시작. 확실합니까?",
            reply_markup=confirm_markup(f"restart:{name}", f"Restart {name}"))
    elif data == "menu:main":
        show_main(chat_id, message_id)
    elif data == "menu:restart":
        api("editMessageText", chat_id=chat_id, message_id=message_id,
            text="Restart할 세션 선택:", reply_markup=session_menu_markup("restart"))
    elif data == "menu:recent":
        api("editMessageText", chat_id=chat_id, message_id=message_id,
            text="최신 대화 볼 세션 선택:", reply_markup=session_menu_markup("recent"))
    elif data == "menu:bypass":
        api("editMessageText", chat_id=chat_id, message_id=message_id,
            text=bypass_menu_text(), reply_markup=bypass_menu_markup())
    elif data.startswith("bypass-toggle:"):
        target = data[len("bypass-toggle:"):]
        BYPASS_DIR.mkdir(parents=True, exist_ok=True)
        if target == "__global__":
            if BYPASS_GLOBAL.exists():
                BYPASS_GLOBAL.unlink()
            else:
                BYPASS_GLOBAL.touch()
        else:
            info = bypass_proj_flag(target)
            if info is not None:
                flag, _ = info
                if flag.exists():
                    flag.unlink()
                else:
                    flag.touch()
        api("editMessageText", chat_id=chat_id, message_id=message_id,
            text=bypass_menu_text(), reply_markup=bypass_menu_markup())
    elif data.startswith("recent:"):
        name = data[len("recent:"):]
        out = read_recent(name)
        send_result_and_menu(chat_id, out)
    elif data.startswith("restart:"):
        name = data[len("restart:"):]
        out = run_cs("restart", name)
        send_result_and_menu(chat_id, f"restart {name}:\n{out}")
    else:
        send_result_and_menu(chat_id, f"unknown: {data}")


def handle_message(msg):
    user_id = msg.get("from", {}).get("id", 0)
    if user_id != ALLOWED_USER:
        api("sendMessage", chat_id=msg.get("chat", {}).get("id"), text="unauthorized")
        return

    chat_id = msg.get("chat", {}).get("id")
    text = (msg.get("text") or "").strip()

    if text in ("/start", "/menu", "menu", "메뉴"):
        show_main(chat_id)
    elif text == "/status":
        out = read_statusline()
        send_result_and_menu(chat_id, out)
    elif text == "/resources":
        out = read_resources()
        send_result_and_menu(chat_id, out)
    elif text == "/list":
        out = run_cs("list")
        send_result_and_menu(chat_id, f"```\n{out}\n```")
    elif text == "/restart_all":
        out = run_cs("restart-all", timeout=60)
        send_result_and_menu(chat_id, f"restart-all:\n{out}")
    elif text.startswith("/restart_"):
        name = text[len("/restart_"):].replace("_", "-")
        out = run_cs("restart", name)
        send_result_and_menu(chat_id, f"restart {name}:\n{out}")
    else:
        # 기본은 메뉴 표시
        show_main(chat_id)


def setup_commands():
    """텔레그램 채팅창 하단 / 버튼에 뜨는 명령어 등록"""
    commands = [
        {"command": "menu", "description": "메인 메뉴"},
        {"command": "list", "description": "모든 세션 상태"},
        {"command": "status", "description": "토큰 사용량/리셋 타임"},
        {"command": "resources", "description": "시스템 리소스 (CPU/MEM/디스크/세션)"},
        {"command": "restart_all", "description": "모든 세션 재시작"},
    ]
    # 각 세션별 restart 명령도 자동 등록
    for name in list_sessions():
        cmd_name = name.replace("-", "_")
        commands.append({"command": f"restart_{cmd_name}", "description": f"{name} 재시작"})
    api("setMyCommands", commands=commands)


def main():
    print(f"[control-bot] start. allowed_user={ALLOWED_USER}", flush=True)
    setup_commands()

    offset = 0
    while True:
        try:
            r = api("getUpdates", offset=offset, timeout=30, allowed_updates=["message", "callback_query"])
            if not r.get("ok"):
                time.sleep(5)
                continue
            for upd in r.get("result", []):
                offset = upd["update_id"] + 1
                if "callback_query" in upd:
                    handle_callback(upd["callback_query"])
                elif "message" in upd:
                    handle_message(upd["message"])
        except KeyboardInterrupt:
            break
        except Exception as e:
            print(f"[loop] {e}", flush=True)
            time.sleep(5)


if __name__ == "__main__":
    main()
