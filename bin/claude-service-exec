#!/bin/bash
# claude-service-exec: systemd ExecStart에서 호출. 현재 디렉토리의 jsonl 존재 여부로
# claude -c (resume) vs claude (fresh) 자동 선택.

set -uo pipefail

# 프로젝트 키 생성: cwd의 / 와 _ 를 - 로 변환 (Claude Code 디렉토리 명명 규칙과 일치)
proj_key=$(pwd | sed -e 's|/|-|g' -e 's|_|-|g')
proj_dir="$HOME/.claude/projects/${proj_key}"

# jsonl 존재 여부 확인
has_jsonl=0
if ls "$proj_dir"/*.jsonl > /dev/null 2>&1; then
    has_jsonl=1
fi

# 모델 강제 핀 (옵트인): 유닛 Environment 에 CLAUDE_MODEL 있으면 --model 로 전달.
# 구독(OAuth) 경로에선 settings model / ANTHROPIC_MODEL env 가 안 먹는 케이스 확인돼 CLI 플래그가 유일 확실. (2026-06-10)
model_arg=""
if [ -n "${CLAUDE_MODEL:-}" ]; then
    model_arg=" --model ${CLAUDE_MODEL}"
fi

# 세션별 모델/effort 설정 (~/.config/claude-models.json, 컨트롤봇 Model 메뉴가 기록).
# { "<proj_key>": {"model": "...", "effort": "low|medium|high"} }
# 우선순위: CLAUDE_MODEL env(유닛 명시 핀) > json. 설정 없거나 값 불량이면 기존 동작 그대로.
MODELS_JSON="$HOME/.config/claude-models.json"
if [ -f "$MODELS_JSON" ]; then
    cfg=$(python3 - "$proj_key" "$MODELS_JSON" <<'PYEOF' 2>/dev/null
import json, re, sys
key, path = sys.argv[1], sys.argv[2]
try:
    entry = json.load(open(path)).get(key) or {}
except Exception:
    entry = {}
model = entry.get("model") or ""
effort = entry.get("effort") or ""
if effort == "mid":
    effort = "medium"
if not re.fullmatch(r"[A-Za-z0-9._-]+", model or "x"):
    model = ""
if effort not in ("low", "medium", "high", "xhigh", "max"):
    effort = ""
print(f"{model}\t{effort}")
PYEOF
)
    json_model="${cfg%%$'\t'*}"
    json_effort="${cfg#*$'\t'}"
    if [ -z "$model_arg" ] && [ -n "$json_model" ]; then
        model_arg=" --model ${json_model}"
    fi
    if [ -n "$json_effort" ]; then
        model_arg="${model_arg} --effort ${json_effort}"
    fi
fi

# exec script with pty (claude --remote-control requires tty)
if [ "$has_jsonl" = "1" ]; then
    exec script -q -c "claude -c${model_arg} --remote-control --channels plugin:telegram@claude-plugins-official" /dev/null < /dev/null
else
    exec script -q -c "claude${model_arg} --remote-control --channels plugin:telegram@claude-plugins-official" /dev/null < /dev/null
fi
