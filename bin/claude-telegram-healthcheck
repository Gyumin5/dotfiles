#!/usr/bin/env python3
"""claude-telegram-healthcheck — 프로젝트 봇 inbound 좀비 감시.

원리(2026-06-05 개정):
정상 세션은 텔레그램 채널을 in-process 로 long-poll 해서 큐(pending)를 즉시
비운다. 봇 채널이 죽으면(좀비) pending 이 계속 안 빠진다.

오발 방지가 핵심이다 — 세션이 긴 작업/깊은 사고(单 턴 16분+ 관측)로 잠깐 폴링을
멈추면 pending 이 일시적으로 쌓였다가 폴링 재개 시 빠진다. 이건 좀비가 아니다.
그래서 "오래된 메시지 1건"(구버전 60s)만으로 판정하지 않고, pending 이 STUCK_SEC
동안 한 번도 0 으로 안 빠진 '지속 적체'일 때만 좀비로 본다.

비침습: 큐 확인은 getWebhookInfo(pending_update_count) 로 한다. 구버전은 getUpdates
를 썼는데, 그건 세션 자신의 long-poll 과 충돌(409)해서 정상 세션 폴링을 방해했다.
getWebhookInfo 는 getUpdates 를 건드리지 않는다.

자동 restart 안 함 — 진행 중 컨텍스트 보호. 알림만. 쿨다운: 세션별 ALERT_COOLDOWN_SEC.
"""

import json
import subprocess
import time
import urllib.parse
import urllib.request
from pathlib import Path

# pending 이 이 시간동안 한 번도 0 으로 안 빠지면 좀비. 세션의 최장 단일 턴
# (deep thinking/long tool, 관측상 ~16-20분)보다 넉넉히 길게 잡아 오발 방지.
STUCK_SEC = 1800            # 30분
ALERT_COOLDOWN_SEC = 3600
HTTP_TIMEOUT = 8

CONTROL_BOT_ENV = Path.home() / ".claude" / "control-bot" / ".env"
CONTROL_CHAT_ID = "8689118207"
STATE_DIR = Path.home() / ".claude" / "state" / "telegram-healthcheck"


def load_env_file(path):
    out = {}
    try:
        for line in Path(path).read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            k, v = line.split("=", 1)
            out[k.strip()] = v.strip().strip('"').strip("'")
    except Exception:
        pass
    return out


def load_control_token():
    return load_env_file(CONTROL_BOT_ENV).get("CONTROL_BOT_TOKEN")


def telegram_post(token, chat_id, text):
    if not token:
        return False
    try:
        url = f"https://api.telegram.org/bot{token}/sendMessage"
        data = urllib.parse.urlencode(
            {"chat_id": chat_id, "text": text, "disable_web_page_preview": "true"}
        ).encode()
        req = urllib.request.Request(url, data=data, method="POST")
        urllib.request.urlopen(req, timeout=HTTP_TIMEOUT).read()
        return True
    except Exception:
        return False


def list_claude_services():
    try:
        out = subprocess.run(
            ["systemctl", "--user", "list-units", "--type=service",
             "--all", "--no-legend", "--plain"],
            capture_output=True, text=True, timeout=10,
        ).stdout
    except Exception:
        return []
    services = []
    for line in out.splitlines():
        parts = line.split()
        if not parts:
            continue
        unit = parts[0]
        if not unit.startswith("claude-") or not unit.endswith(".service"):
            continue
        if unit == "claude-control-bot.service":
            continue
        # only loaded units
        if "loaded" not in line and "active" not in line:
            continue
        services.append(unit)
    return services


def svc_telegram_state_dir(unit):
    try:
        out = subprocess.run(
            ["systemctl", "--user", "show", "-p", "Environment", "--value", unit],
            capture_output=True, text=True, timeout=5,
        ).stdout.strip()
    except Exception:
        return None
    for tok in out.split():
        if tok.startswith("TELEGRAM_STATE_DIR="):
            return tok.split("=", 1)[1]
    return None


def pending_count(token):
    """getWebhookInfo 의 pending_update_count. None=확인 불가(에러).
    getUpdates 를 건드리지 않아 세션 long-poll 과 충돌하지 않음(비침습)."""
    try:
        url = f"https://api.telegram.org/bot{token}/getWebhookInfo"
        with urllib.request.urlopen(url, timeout=HTTP_TIMEOUT) as r:
            data = json.loads(r.read())
        if not data.get("ok"):
            return None
        return int(data.get("result", {}).get("pending_update_count", 0))
    except Exception:
        return None


def _nonzero_file(unit):
    return STATE_DIR / f"{unit}.nonzero_since"


def stuck_since(unit, pending):
    """pending 이 연속으로 ≥1 인 streak 의 시작 시각을 추적.
    pending==0 이면 streak 리셋. 반환=streak 시작 ts(없으면 now)."""
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    f = _nonzero_file(unit)
    now = time.time()
    if pending <= 0:
        try:
            f.unlink()
        except FileNotFoundError:
            pass
        return None
    # pending >= 1
    try:
        return float(f.read_text().strip())
    except Exception:
        f.write_text(str(now))
        return now


def cooldown_ok(unit):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    f = STATE_DIR / f"{unit}.alerted"
    if not f.is_file():
        return True
    age = time.time() - f.stat().st_mtime
    return age >= ALERT_COOLDOWN_SEC


def mark_alerted(unit):
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    (STATE_DIR / f"{unit}.alerted").touch()


def main():
    control_token = load_control_token()
    results = []
    now = time.time()
    for unit in list_claude_services():
        state_dir = svc_telegram_state_dir(unit)
        if not state_dir:
            continue
        env_path = Path(state_dir) / ".env"
        if not env_path.is_file():
            continue
        env = load_env_file(env_path)
        token = env.get("TELEGRAM_BOT_TOKEN") or env.get("BOT_TOKEN")
        if not token:
            continue
        n = pending_count(token)
        if n is None:
            results.append((unit, "api_error", 0, 0))
            continue
        since = stuck_since(unit, n)
        stuck_for = max(0, int(now - since)) if since else 0
        zombie = n >= 1 and since is not None and stuck_for >= STUCK_SEC
        results.append((unit, "zombie" if zombie else "ok", n, stuck_for))
        if zombie and cooldown_ok(unit):
            session = unit.replace("claude-", "").replace(".service", "")
            mins = stuck_for // 60
            msg = (
                f"⚠ telegram-healthcheck: {session} 봇 inbound 적체 의심\n"
                f"pending={n}, {mins}분째 안 빠짐 (임계 {STUCK_SEC // 60}분)\n"
                f"세션이 멈췄거나 텔레그램 채널이 죽었을 수 있음.\n"
                f"권고: cs restart {session}"
            )
            if telegram_post(control_token, CONTROL_CHAT_ID, msg):
                mark_alerted(unit)
    # one-line summary to stdout (for journalctl)
    summary = " | ".join(f"{u}:{s}:p{n}/s{a}" for u, s, n, a in results)
    print(summary or "no-services")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
