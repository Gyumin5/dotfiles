#!/usr/bin/env python3
"""
claude-unused-capability-report — 읽기전용 근거 리포트.

정의된 capability(스킬/서브에이전트/MCP 서버)와 telemetry 사용기록을 대조해
"최근 N일 안에 관측됐는가" 를 표로 낸다. 삭제/비활성화 판단은 하지 않는다 —
사람이 정리(분기별)할 때 참고할 근거만 제공.

읽기 전용. 네트워크/모델/MCP/Telegram/systemd/설정변경 일절 없음.
입력(있으면 읽고, 없으면 '근거 없음'):
  - ~/.claude/telemetry/skill-calls.jsonl   {ts, project, skill, ...}
  - ~/.claude/telemetry/ai-calls.jsonl      {ts, project, provider, ...}
  - <repo>/claude/skills/*/ , ~/.claude/skills/*/  (SKILL.md 보유 디렉터리)
  - <repo>/claude/agents/*.md , ~/.claude/agents/*.md (서브에이전트 정의)
  - <repo>/claude/mcp.json , ~/.claude/mcp.json (MCP 서버 이름)

사용법: claude-unused-capability-report [--days N] [--json]
"""
import argparse
import json
import os
import sys
from datetime import datetime, timezone
from pathlib import Path

HOME = Path.home()
REPO = Path(__file__).resolve().parent.parent
TELE = HOME / ".claude" / "telemetry"
SKILL_LOG = TELE / "skill-calls.jsonl"
AI_LOG = TELE / "ai-calls.jsonl"


def parse_ts(s):
    try:
        return datetime.fromisoformat(str(s).replace("Z", "+00:00"))
    except Exception:
        return None


def read_jsonl(path):
    if not path.is_file():
        return None  # 구분: None=파일없음, []=비어있음
    out = []
    try:
        for line in path.read_text(errors="ignore").splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                out.append(json.loads(line))
            except Exception:
                continue
    except Exception:
        return None
    return out


def agg_usage(records, key, now, days):
    """records 에서 key 필드별 {count_window, last_seen} 집계."""
    info = {}
    if not records:
        return info
    cutoff = now.timestamp() - days * 86400
    for r in records:
        name = r.get(key)
        if not name:
            continue
        ts = parse_ts(r.get("ts"))
        d = info.setdefault(name, {"count_window": 0, "last_seen": None, "count_total": 0})
        d["count_total"] += 1
        if ts:
            if d["last_seen"] is None or ts > d["last_seen"]:
                d["last_seen"] = ts
            if ts.timestamp() >= cutoff:
                d["count_window"] += 1
    return d_fix(info)


def d_fix(info):
    for d in info.values():
        d["last_seen"] = d["last_seen"].isoformat() if d["last_seen"] else None
    return info


def find_skills():
    """{name: [정의위치...]}"""
    res = {}
    for base in [REPO / "claude" / "skills", HOME / ".claude" / "skills"]:
        if not base.is_dir():
            continue
        for child in sorted(base.iterdir()):
            if child.is_dir() and (child / "SKILL.md").is_file():
                res.setdefault(child.name, []).append(str(child))
            elif child.is_symlink() and child.is_dir():
                res.setdefault(child.name, []).append(str(child) + " (symlink)")
    return res


def find_agents():
    res = {}
    for base in [REPO / "claude" / "agents", HOME / ".claude" / "agents",
                 REPO / "agents"]:
        if not base.is_dir():
            continue
        for child in sorted(base.iterdir()):
            if child.is_file() and child.suffix == ".md":
                res.setdefault(child.stem, []).append(str(child))
    return res


def find_mcp():
    res = {}
    for cfg in [REPO / "claude" / "mcp.json", HOME / ".claude" / "mcp.json"]:
        if not cfg.is_file():
            continue
        try:
            d = json.loads(cfg.read_text(errors="ignore"))
        except Exception:
            continue
        servers = d.get("mcpServers") or {}
        for name in servers:
            res.setdefault(name, []).append(str(cfg))
    return res


def status_for(name, usage, usage_missing):
    if usage_missing:
        return "no_telemetry"
    u = usage.get(name)
    if not u or u["count_total"] == 0:
        return "unused(근거없음)"
    if u["count_window"] > 0:
        return "observed"
    return "stale(>기간)"


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--days", type=int, default=90)
    ap.add_argument("--json", action="store_true")
    a = ap.parse_args()

    now = datetime.now(timezone.utc)
    skill_recs = read_jsonl(SKILL_LOG)
    ai_recs = read_jsonl(AI_LOG)
    skill_usage = agg_usage(skill_recs, "skill", now, a.days)
    ai_usage = agg_usage(ai_recs, "provider", now, a.days)

    skills = find_skills()
    agents = find_agents()
    mcp = find_mcp()

    rows = []  # kind, name, def_loc, source_log, count_window, last_seen, status

    for name, locs in sorted(skills.items()):
        rows.append(("skill", name, "; ".join(locs), str(SKILL_LOG),
                     skill_usage.get(name, {}).get("count_window", 0),
                     skill_usage.get(name, {}).get("last_seen"),
                     status_for(name, skill_usage, skill_recs is None)))
    # telemetry 에는 있는데 정의 못 찾은 스킬(플러그인 등)
    for name in sorted(skill_usage):
        if name not in skills:
            u = skill_usage[name]
            rows.append(("skill", name, "(정의 미발견 — 플러그인?)", str(SKILL_LOG),
                         u["count_window"], u["last_seen"], "def_not_found"))

    for name, locs in sorted(agents.items()):
        rows.append(("subagent", name, "; ".join(locs), "(telemetry 없음)",
                     "-", "-", "no_telemetry"))

    for name, locs in sorted(mcp.items()):
        rows.append(("mcp", name, "; ".join(locs), "(telemetry 없음)",
                     "-", "-", "no_telemetry"))

    # ai provider 사용 요약(참고)
    ai_rows = []
    for name in sorted(ai_usage):
        u = ai_usage[name]
        ai_rows.append(("ai-provider", name, u["count_window"], u["last_seen"]))

    if a.json:
        print(json.dumps({
            "generated": now.isoformat(), "days": a.days,
            "rows": [dict(zip(
                ["kind","name","def_location","source_log","count_window","last_seen","status"], r))
                for r in rows],
            "ai_providers": [dict(zip(["kind","name","count_window","last_seen"], r)) for r in ai_rows],
            "telemetry_present": {"skill-calls": skill_recs is not None,
                                   "ai-calls": ai_recs is not None},
        }, ensure_ascii=False, indent=2))
        return

    print(f"# 미사용 capability 근거 리포트 ({now.date()})")
    print()
    print(f"- 생성: {now.isoformat()}  (KST 변환은 +9h)")
    print(f"- 윈도우: 최근 {a.days}일")
    print(f"- telemetry: skill-calls={'있음' if skill_recs is not None else '없음(근거 없음)'}, "
          f"ai-calls={'있음' if ai_recs is not None else '없음(근거 없음)'}")
    print("- ⚠️ 삭제/비활성화 판단 금지. 이건 읽기전용 근거 리포트일 뿐. "
          "정리는 사람이 ADR + 복구경로 남기고 결정.")
    print("- status: observed=윈도우 내 사용, stale=윈도우 밖 마지막 사용, "
          "unused=기록 없음, no_telemetry=수집 안 됨, def_not_found=정의 미발견.")
    print()
    print("| kind | name | count(win) | last_seen | status | def_location |")
    print("|---|---|---|---|---|---|")
    for kind, name, loc, _src, cw, ls, st in rows:
        print(f"| {kind} | {name} | {cw} | {ls or '-'} | {st} | {loc} |")
    if ai_rows:
        print()
        print("## AI provider 사용(참고, ai-calls.jsonl)")
        print("| provider | count(win) | last_seen |")
        print("|---|---|---|")
        for _k, name, cw, ls in ai_rows:
            print(f"| {name} | {cw} | {ls or '-'} |")
    print()
    print("_근거가 부족하면(예: telemetry 비어있음) 미사용으로 단정하지 말 것._")


if __name__ == "__main__":
    main()
