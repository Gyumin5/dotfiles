#!/bin/bash
# claude-watchdog: claude-*.service 건강 감시. 매 1분 실행 (systemd timer).
# 처리: failed 복구 / 한도 패턴 감지 / jsonl 무응답 감지.
# 순수 bash — claude 의존성 없음.

set -uo pipefail

LOG_DIR="/home/gmoh/.claude/logs"
STATE_DIR="/home/gmoh/.claude/state/watchdog"
mkdir -p "$STATE_DIR"

# backoff 설정 (jsonl stuck 재시작 간격: 15min → 1h → 포기)
BACKOFF_MIN=(0 15 60)

log() {
    echo "[$(date -Iseconds)] $1" >> "$LOG_DIR/watchdog.log"
}

telegram_alert() {
    local text="$1"
    # test_claude 봇으로 운영자에게 알림
    local env="/home/gmoh/test_claude/.claude/telegram/.env"
    [ ! -f "$env" ] && return 0
    # shellcheck disable=SC1090
    . "$env"
    local tok="${TELEGRAM_BOT_TOKEN:-${BOT_TOKEN:-}}"
    [ -z "$tok" ] && return 0
    curl -s -m 5 -X POST "https://api.telegram.org/bot${tok}/sendMessage" \
        --data-urlencode "chat_id=8689118207" \
        --data-urlencode "text=${text}" > /dev/null 2>&1 || true
}

# === 1. enabled claude-*.service 순회 ===
for unit in $(systemctl --user list-unit-files 'claude-*.service' --state=enabled --no-legend 2>/dev/null | awk '{print $1}'); do
    [[ "$unit" == "claude-watchdog.service" ]] && continue

    state=$(systemctl --user is-active "$unit" 2>/dev/null)

    # --- 1a. failed → reset + start ---
    if [ "$state" = "failed" ]; then
        log "$unit failed → reset + start"
        systemctl --user reset-failed "$unit"
        systemctl --user start "$unit"
        continue
    fi

    # --- 1b. inactive는 건드리지 않음 (사용자 의도 stop 존중) ---
    [ "$state" != "active" ] && continue

    # --- 2. 한도 패턴 체크 (statusline_cache.json 기반) ---
    log_file="$LOG_DIR/${unit%.service}.log"
    if [ -f "$log_file" ] && tail -200 "$log_file" 2>/dev/null | grep -q "hit your limit"; then
        # 서비스 로그에 한도 흔적 있음. 실제 한도가 풀렸는지 statusline_cache.json으로 확인
        cache_file="/home/gmoh/.claude/statusline_cache.json"
        if [ -f "$cache_file" ]; then
            rl5_pct=$(python3 -c "
import json
try:
    d=json.load(open('$cache_file'))
    p=d.get('rate_limits',{}).get('five_hour',{}).get('used_percentage',100)
    print(p if p is not None else 100)
except: print(100)
" 2>/dev/null)
            rate_state="$STATE_DIR/${unit%.service}.ratelimit"
            cur_reset=$(python3 -c "
import json
try:
    d=json.load(open('$cache_file'))
    print(d.get('rate_limits',{}).get('five_hour',{}).get('resets_at',0))
except: print(0)
" 2>/dev/null)

            # rl5가 70% 미만 = 한도 풀림. 이번 리셋에 대해 아직 restart 안 했으면 깨움.
            RESET_BUFFER_SEC=60
            now_epoch=$(date +%s)

            if [ "${rl5_pct:-100}" -lt 70 ]; then
                # 리셋 감지. 버퍼 확인: 마지막 'hit your limit' 로그 mtime + 버퍼
                if [ ! -f "$rate_state" ] || [ "$(cat "$rate_state" 2>/dev/null)" != "$cur_reset" ]; then
                    log "$unit 한도 리셋 감지 (rl5=${rl5_pct}%) → restart"
                    telegram_alert "⚠ $unit 한도 리셋 도달 (5h=${rl5_pct}%). 재시작 시도."
                    systemctl --user restart "$unit"
                    echo "$cur_reset" > "$rate_state"
                fi
            else
                log "$unit rate limited (rl5=${rl5_pct}%) → 대기"
            fi
            continue
        fi
    else
        # 한도 걸렸던 state 파일 정리 (로그에 더 이상 패턴 없음)
        rm -f "$STATE_DIR/${unit%.service}.ratelimit"
    fi

    # --- 3. jsonl 무응답 체크 (선택적) ---
    wd=$(systemctl --user show "$unit" -p WorkingDirectory 2>/dev/null | cut -d= -f2)
    [ -z "$wd" ] && continue
    proj_key=$(echo "$wd" | sed 's|/|-|g')
    latest_jsonl=$(ls -t "/home/gmoh/.claude/projects/${proj_key}"/*.jsonl 2>/dev/null | head -1)
    [ -z "$latest_jsonl" ] && continue

    now=$(date +%s)
    mtime=$(stat -c %Y "$latest_jsonl" 2>/dev/null || echo 0)
    age=$(( now - mtime ))

    # 서비스가 활성인데 jsonl이 2시간 이상 안 변함 → stuck 후보
    # 대화 중이 아닌 유휴 세션일 수도 있으니 보수적으로 6시간 기준
    STUCK_AGE_SEC=21600  # 6h

    if [ "$age" -ge "$STUCK_AGE_SEC" ]; then
        # 최근 jsonl에 응답 대기 중인 queue-operation이 있는지 (진짜 멈춤)
        if tail -20 "$latest_jsonl" 2>/dev/null | grep -q '"type":"queue-operation"'; then
            # queue는 있는데 오래 응답 없음 → stuck
            backoff_state="$STATE_DIR/${unit%.service}.backoff"
            attempt=0
            last_try=0
            if [ -f "$backoff_state" ]; then
                attempt=$(awk -F= '$1=="attempt"{print $2}' "$backoff_state")
                last_try=$(awk -F= '$1=="last_try"{print $2}' "$backoff_state")
                attempt="${attempt:-0}"
                last_try="${last_try:-0}"
            fi

            # backoff 대기 중인지 확인
            wait_min="${BACKOFF_MIN[$attempt]:-0}"
            if [ "$attempt" -gt 0 ] && [ $(( now - last_try )) -lt $(( wait_min * 60 )) ]; then
                log "$unit stuck 대기 중 (attempt=$attempt, ${wait_min}분 backoff)"
                continue
            fi

            attempt=$(( attempt + 1 ))
            if [ "$attempt" -gt "${#BACKOFF_MIN[@]}" ]; then
                log "$unit stuck backoff 초과 → 수동 점검 필요"
                telegram_alert "🚨 $unit stuck ${age}s. 자동 복구 포기. 수동 점검 필요."
                rm -f "$backoff_state"
                continue
            fi

            log "$unit stuck (jsonl ${age}s) → restart (attempt=$attempt)"
            telegram_alert "⚠ $unit 무응답 ${age}s. 재시작 (attempt=$attempt)."
            systemctl --user restart "$unit"
            echo "attempt=$attempt" > "$backoff_state"
            echo "last_try=$now" >> "$backoff_state"
        fi
    else
        # 활성 응답 있음 → backoff 카운터 리셋
        rm -f "$STATE_DIR/${unit%.service}.backoff"
    fi
done
