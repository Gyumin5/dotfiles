#!/bin/bash
# claude-sessions: 모든 claude 세션 통합 관리 CLI.
# Termius/SSH에서 원격 호출 가능. claude 프로세스 독립적으로 동작.
#
# 사용법:
#   claude-sessions list              # 모든 세션 상태
#   claude-sessions restart-all       # 전부 킬+재시작
#   claude-sessions restart <name>    # 특정 세션 (unit 이름: claude-<name>)
#   claude-sessions rotate <name>     # fresh 시작 (jsonl 아카이브로 이동, -c 없이 새 세션)
#   claude-sessions kill-orphans      # 고아 bun 청소
#   claude-sessions health            # stuck 세션 감지

set -uo pipefail

cmd="${1:-help}"

list_services() {
    systemctl --user list-unit-files 'claude-*.service' --state=enabled --no-legend 2>/dev/null \
        | awk '{print $1}' \
        | grep -v '^claude-watchdog.service$' \
        | grep -v '^claude-control-bot.service$'
}

cmd_list() {
    echo "=== systemd 관리 세션 ==="
    for svc in $(list_services); do
        state=$(systemctl --user is-active "$svc" 2>/dev/null)
        pid=$(systemctl --user show "$svc" -p MainPID 2>/dev/null | cut -d= -f2)
        [ "$pid" = "0" ] && pid="-"
        etime="-"
        [ "$pid" != "-" ] && etime=$(ps -o etime= -p "$pid" 2>/dev/null | tr -d ' ')
        printf "  %-30s %-10s PID=%-10s uptime=%s\n" "$svc" "$state" "$pid" "$etime"
    done
    echo ""
    echo "=== cl 또는 수동 기동 세션 (systemd 밖) ==="
    for p in $(pgrep -f "^claude.*remote-control" 2>/dev/null); do
        cwd=$(readlink /proc/$p/cwd 2>/dev/null)
        # systemd 관리 세션은 cgroup이 claude-*.service에 속함
        cg=$(grep -oP 'user\.slice/user-\d+\.slice/user@\d+\.service/\K[^ ]+' "/proc/$p/cgroup" 2>/dev/null | head -1)
        if [[ "$cg" != claude-*.service ]]; then
            et=$(ps -o etime= -p "$p" | tr -d ' ')
            printf "  PID=%-10s uptime=%-8s cwd=%s\n" "$p" "$et" "$cwd"
        fi
    done
}

cmd_restart() {
    local name="${1:?usage: claude-sessions restart <name>}"
    local svc="claude-${name}.service"
    local wd=$(systemctl --user show "$svc" -p WorkingDirectory --value 2>/dev/null)
    local bot_pid_path="${wd}/.claude/telegram/bot.pid"
    local need_bot=0
    [ -d "${wd}/.claude/telegram" ] && need_bot=1

    for attempt in 1 2 3; do
        echo "[$(date '+%H:%M:%S')] restart $svc (attempt $attempt)"
        systemctl --user reset-failed "$svc" 2>/dev/null
        systemctl --user restart "$svc"

        if [ "$need_bot" = "0" ]; then
            return 0
        fi

        # 봇 spawn 확인 (최대 8s 대기)
        for i in 1 2 3 4 5 6 7 8; do
            sleep 1
            if [ -f "$bot_pid_path" ]; then
                # bot.pid는 stop 시 안 지워질 수 있음. 실제 PID 살아있는지 확인
                local pid=$(cat "$bot_pid_path" 2>/dev/null)
                if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
                    echo "  ✅ telegram bot alive (pid=$pid)"
                    return 0
                fi
            fi
        done
        echo "  ⚠ telegram bot not detected after 8s, retrying..."
    done
    echo "  ❌ telegram bot still not up after 3 attempts"
    return 1
}

cmd_rotate() {
    local name="${1:?usage: claude-sessions rotate <name>}"
    local svc="claude-${name}.service"
    local wd=$(systemctl --user show "$svc" -p WorkingDirectory 2>/dev/null | cut -d= -f2)
    if [ -z "$wd" ]; then
        echo "[rotate] $svc not found"
        return 1
    fi
    local proj_key=$(echo "$wd" | sed 's|/|-|g')
    local proj_dir="/home/gmoh/.claude/projects/${proj_key}"
    local archive="${proj_dir}/archive"
    mkdir -p "$archive"
    local ts=$(date +%Y%m%d-%H%M%S)

    echo "[$(date '+%H:%M:%S')] rotating $svc (cwd=$wd)"

    # rotate 실행 주체가 해당 service cgroup 안에 있으면 stop이 자기 자신을 kill함.
    # systemd-run --scope로 detach시켜서 실행 (caller가 죽어도 살아남음).
    # --collect로 완료 시 자동 정리.
    # transient scope에서 실행하면 user.slice 직속이라 claude-*.service cgroup 밖에 위치.

    local rotate_cmd='
set -uo pipefail
systemctl --user reset-failed "'"$svc"'" 2>/dev/null
systemctl --user stop "'"$svc"'"
sleep 3
moved=0
for jsonl in "'"$proj_dir"'"/*.jsonl; do
    [ -f "$jsonl" ] || continue
    mv "$jsonl" "'"$archive"'"/$(basename "$jsonl" .jsonl).'"$ts"'.jsonl
    moved=$((moved+1))
done
echo "archived $moved jsonl(s)"
systemctl --user start "'"$svc"'"
sleep 2
echo "state=$(systemctl --user is-active "'"$svc"'")"
'

    # systemd-run으로 detach 실행. 현재 cgroup(claude-*.service) 밖에서 돌아감.
    systemd-run --user --unit="cs-rotate-${name}-${ts}" --collect --quiet \
        /bin/bash -c "$rotate_cmd"
    echo "  rotate 명령 detach됨. systemd-run으로 claude service cgroup 밖에서 실행 중."
    echo "  완료 확인: systemctl --user status cs-rotate-${name}-${ts}"
    echo "  또는 journalctl --user -u cs-rotate-${name}-${ts}"
}

cmd_restart_all() {
    for svc in $(list_services); do
        echo "[$(date '+%H:%M:%S')] restart $svc"
        systemctl --user reset-failed "$svc" 2>/dev/null
        systemctl --user restart "$svc" &
    done
    wait
    echo "모든 세션 재시작 명령 전송 완료"
}

cmd_kill_orphans() {
    local killed=0
    for p in $(pgrep -af "bun server.ts" 2>/dev/null | awk '{print $1}'); do
        ppid=$(ps -o ppid= -p "$p" 2>/dev/null | tr -d ' ')
        # parent가 systemd-user(보통 PID < 10000, /lib/systemd/systemd --user)면 고아
        if [ -n "$ppid" ]; then
            pcmd=$(ps -o command= -p "$ppid" 2>/dev/null)
            if [[ "$pcmd" == *"systemd --user"* ]]; then
                dir=$(tr '\0' '\n' < "/proc/$p/environ" 2>/dev/null | grep TELEGRAM_STATE_DIR | cut -d= -f2)
                echo "orphan bun $p (dir=$dir) → kill"
                kill -KILL "$p" 2>/dev/null
                killed=$((killed+1))
            fi
        fi
    done
    echo "killed $killed orphan(s)"
}

cmd_health() {
    echo "=== 세션 상태 ==="
    for svc in $(list_services); do
        state=$(systemctl --user is-active "$svc" 2>/dev/null)
        wd=$(systemctl --user show "$svc" -p WorkingDirectory | cut -d= -f2)
        proj=$(basename "$wd")

        if [ "$state" != "active" ]; then
            printf "  %-25s %s\n" "$proj" "⏹ 꺼짐"
            continue
        fi

        # 최근 jsonl 찾기
        proj_dir_key=$(echo "$wd" | sed 's|/|-|g')
        jsonl=$(ls -t "/home/gmoh/.claude/projects/${proj_dir_key}"/*.jsonl 2>/dev/null | head -1)

        if [ -z "$jsonl" ]; then
            printf "  %-25s %s\n" "$proj" "✅ 켜짐 (새 세션)"
            continue
        fi

        now=$(date +%s)
        mtime=$(stat -c %Y "$jsonl")
        age=$(( now - mtime ))
        age_h=$(( age / 3600 ))

        # 로그에서 한도 패턴 체크
        log="/home/gmoh/.claude/logs/${svc%.service}.log"
        hit_limit=""
        reset_time=""
        if [ -f "$log" ]; then
            if tail -200 "$log" 2>/dev/null | grep -q "hit your limit"; then
                hit_limit="yes"
                reset_time=$(tail -200 "$log" | grep "hit your limit" | tail -1 | grep -oP 'resets \K[0-9]+[ap]m' | head -1)
            fi
        fi

        flag="✅ 켜짐"
        [ -n "$hit_limit" ] && flag="⚠ RATE_LIMIT(reset=$reset_time)"
        printf "  %-25s %s  age=%dh\n" "$proj" "$flag" "$age_h"
    done
}

case "$cmd" in
    list|ls)          cmd_list ;;
    restart)          shift; cmd_restart "$@" ;;
    rotate)           shift; cmd_rotate "$@" ;;
    restart-all)      cmd_restart_all ;;
    kill-orphans)     cmd_kill_orphans ;;
    health)           cmd_health ;;
    help|-h|--help|*)
        cat <<'HELP'
claude-sessions <command>

Commands:
  list                   모든 세션 상태
  restart <name>         특정 세션 재시작 (claude -c로 resume, 맥락 유지)
  rotate <name>          fresh 시작 (jsonl을 archive/로 이동, 새 세션)
                         — progress.md/history.md 잘 관리된 경우 추천
  restart-all            모든 enabled 세션 재시작
  kill-orphans           고아 bun 프로세스 청소
  health                 stuck/rate-limit 세션 감지
  help                   이 도움말

Examples:
  claude-sessions list
  claude-sessions restart test-claude
  claude-sessions rotate test-claude
  claude-sessions restart-all
HELP
        ;;
esac
